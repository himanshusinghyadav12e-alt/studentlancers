# StudentLancers.com — environment template
#
# Copy this file to `.env` and fill in real values from your Supabase
# project dashboard (Project Settings → API).
#
# `PUBLIC_*` vars are exposed to the browser; everything else is
# server-only. The service role key MUST NOT be exposed to clients.

# Public — used in the browser and on the server.
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# Server-only. Never prefix with PUBLIC_, never import from client code.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# Public site URL — used to build absolute redirect URLs for OAuth
# and password reset callbacks. Set to your deployed origin in
# production (e.g. https://studentlancers.com) and to http://localhost:4321
# in dev.
PUBLIC_SITE_URL="http://localhost:4321"
