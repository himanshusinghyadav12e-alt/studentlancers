---
/**
 * /auth/callback
 *
 * OAuth / magic-link return URL. Supabase appends `?code=…` to the
 * `redirectTo` we set when starting the flow; this page exchanges
 * the code for a session, then redirects to the role's dashboard (or
 * the safe `?next=` target if the URL has one).
 */
import { getSupabase } from '../../lib/supabase';
import { publicEnv } from '../../lib/env';

const supabase = getSupabase(Astro);
const code = Astro.url.searchParams.get('code');
const rawNext = Astro.url.searchParams.get('next');

let error: string | null = null;
if (code) {
  const { error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);
  if (exchangeError) error = exchangeError.message;
} else {
  error = 'Missing authorization code.';
}

// If the exchange succeeded, fetch the user to learn their role so
// we can route to the right dashboard.
let redirectTo = '/login';
if (!error) {
  const { data: { user } } = await supabase.auth.getUser();
  if (user) {
    const { data: profile } = await supabase
      .from('users')
      .select('role')
      .eq('id', user.id)
      .maybeSingle();
    const role = (profile as { role?: 'student' | 'company' } | null)?.role ?? 'student';
    const fallback = role === 'company' ? '/company/dashboard' : '/student/dashboard';
    // Same-origin absolute path only — drop protocol-relative and
    // external URLs to prevent open-redirects.
    const isSafe =
      !!rawNext &&
      rawNext.startsWith('/') &&
      !rawNext.startsWith('//') &&
      rawNext !== '/login' &&
      rawNext !== '/signup' &&
      rawNext !== '/forgot-password';
    redirectTo = isSafe ? (rawNext as string) : fallback;
  }
}

if (error) {
  // Render a minimal error page; the layout can be improved later
  // but this is the failure path so we keep it tight.
  return Astro.redirect(
    `/login?error=${encodeURIComponent(error)}`,
    303,
  );
}

return Astro.redirect(redirectTo, 303);
---
