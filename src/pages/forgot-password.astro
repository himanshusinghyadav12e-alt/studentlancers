---
import AuthLayout from '../layouts/AuthLayout.astro';
import Input from '../components/ui/Input.astro';
import Field from '../components/ui/Field.astro';
import Button from '../components/ui/Button.astro';

/**
 * /forgot-password
 *
 * Two states in the same form: the request state (email + reset
 * button) and the success state (sent confirmation + try-again
 * link). The client script toggles between them and the success
 * block is hidden by default to keep the page free of layout shift
 * for users without JS.
 */
---

<AuthLayout
  title="Reset your password · StudentLancers"
  description="Reset your StudentLancers password in a few minutes."
  eyebrow="Account recovery"
  heading="Reset your password"
  subheading="Enter the email on your account and we will send a secure link to set a new password."
>
  <form
    class="auth-form"
    novalidate
    aria-describedby="forgot-alert"
    data-auth-form="forgot"
  >
    <div
      id="forgot-alert"
      class="auth-alert"
      role="alert"
      data-form-alert
      hidden
    >
      <svg class="auth-alert__icon" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.4" />
        <path d="M9 5.5v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        <circle cx="9" cy="12.4" r="0.9" fill="currentColor" />
      </svg>
      <div class="auth-alert__body">
        <p class="auth-alert__title" data-form-alert-title>Something went wrong.</p>
        <p class="auth-alert__msg" data-form-alert-msg>Please try again.</p>
      </div>
    </div>

    <div data-request-state>
      <Field label="Email" for="forgot-email">
        <Input
          type="email"
          id="forgot-email"
          name="email"
          size="lg"
          placeholder="you@university.edu"
          autocomplete="email"
          required
          data-field="email"
        />
      </Field>

      <div style="margin-top: var(--space-md);">
        <Button
          variant="primary"
          size="lg"
          type="submit"
          class="auth-submit"
          data-submit
        >
          <span class="auth-submit__spinner" aria-hidden="true"></span>
          <span data-submit-label>Send reset link</span>
        </Button>
      </div>

      <p class="auth-switch" style="margin-top: var(--space-md);">
        Remembered it? <a href="/login">Back to log in</a>
      </p>
    </div>

    <div class="auth-success" data-success-state hidden role="status" aria-live="polite">
      <span class="auth-success__icon" aria-hidden="true">
        <svg viewBox="0 0 28 28" fill="none">
          <path d="M6 14.5l5 5L22 8.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <h2 class="auth-success__title">Check your inbox</h2>
      <p class="auth-success__body">
        We sent a password reset link to
        <span class="auth-success__email" data-success-email>you@university.edu</span>.
        The link expires in 30 minutes.
      </p>
      <Button
        variant="secondary"
        size="md"
        type="button"
        data-resend
      >
        Didn’t get it? Resend
      </Button>
      <p class="auth-switch" style="margin-top: var(--space-xs);">
        <a href="/login">Back to log in</a>
      </p>
    </div>
  </form>
</AuthLayout>

<script>
  import { mountAuthForms } from '../scripts/auth-form';
  mountAuthForms();
</script>
