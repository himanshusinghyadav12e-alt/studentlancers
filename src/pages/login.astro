---
import AuthLayout from '../layouts/AuthLayout.astro';
import Input from '../components/ui/Input.astro';
import Field from '../components/ui/Field.astro';
import Button from '../components/ui/Button.astro';

/**
 * /login
 *
 * Token-driven form built on top of the existing Input/Field/Button
 * primitives. Client-side validation and password show/hide are wired
 * up in /scripts/auth-form.ts.
 */
---

<AuthLayout
  title="Log in · StudentLancers"
  description="Log in to your StudentLancers account to find work or hire college talent."
  eyebrow="Welcome back"
  heading="Log in to StudentLancers"
  subheading="Pick up where you left off — briefs, applicants, and payouts in one place."
>
  <form
    class="auth-form"
    novalidate
    aria-describedby="login-alert"
    data-auth-form="login"
  >
    <div
      id="login-alert"
      class="auth-alert"
      role="alert"
      data-form-alert
      hidden
    >
      <svg class="auth-alert__icon" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.4" />
        <path d="M9 5.5v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        <circle cx="9" cy="12.4" r="0.9" fill="currentColor" />
      </svg>
      <div class="auth-alert__body">
        <p class="auth-alert__title" data-form-alert-title>Something went wrong.</p>
        <p class="auth-alert__msg" data-form-alert-msg>Please try again.</p>
      </div>
    </div>

    <Field label="Email" for="login-email">
      <Input
        type="email"
        id="login-email"
        name="email"
        size="lg"
        placeholder="you@university.edu"
        autocomplete="email"
        required
        data-field="email"
      />
    </Field>

    <Field label="Password" for="login-password">
      <span class="auth-input-wrap">
        <Input
          type="password"
          id="login-password"
          name="password"
          size="lg"
          placeholder="Your password"
          autocomplete="current-password"
          required
          minlength="8"
          data-field="password"
        />
        <button
          type="button"
          class="auth-input-toggle"
          aria-label="Show password"
          aria-pressed="false"
          data-password-toggle
          data-target="login-password"
        >
          <svg class="auth-input-toggle__show" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1.5 8s2.5-4.5 6.5-4.5S14.5 8 14.5 8 12 12.5 8 12.5 1.5 8 1.5 8Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4" />
          </svg>
          <svg class="auth-input-toggle__hide" viewBox="0 0 16 16" fill="none" aria-hidden="true" hidden>
            <path d="M2 2l12 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M3.5 8c.7-1 2.2-2.7 4.5-2.7 1.1 0 2.1.4 2.9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M6.5 10.5c.5.3 1 .5 1.5.5 2.3 0 3.8-1.7 4.5-2.7-.3-.4-.7-.9-1.2-1.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
        </button>
      </span>
    </Field>

    <div class="auth-row">
      <label class="auth-check">
        <span class="auth-check__box" aria-hidden="true">
          <svg viewBox="0 0 12 12" fill="none">
            <path d="M2.5 6.5l2.5 2.5L9.5 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <input
          type="checkbox"
          class="auth-check__input"
          name="remember"
          id="login-remember"
        />
        <span>Remember me for 30 days</span>
      </label>
      <a class="auth-link" href="/forgot-password">Forgot password?</a>
    </div>

    <Button
      variant="primary"
      size="lg"
      type="submit"
      class="auth-submit"
      data-submit
    >
      <span class="auth-submit__spinner" aria-hidden="true"></span>
      <span data-submit-label>Log in</span>
    </Button>

    <div class="auth-divider" role="separator" aria-label="Or continue with">
      <span>or</span>
    </div>

    <button type="button" class="auth-google" data-google-signin aria-label="Continue with Google">
      <svg viewBox="0 0 18 18" aria-hidden="true">
        <path d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92a8.78 8.78 0 0 0 2.68-6.62Z" fill="#4285F4" />
        <path d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.8.54-1.84.86-3.04.86-2.34 0-4.32-1.58-5.03-3.71H.96v2.33A9 9 0 0 0 9 18Z" fill="#34A853" />
        <path d="M3.97 10.71A5.41 5.41 0 0 1 3.68 9c0-.6.1-1.17.29-1.71V4.96H.96A9 9 0 0 0 0 9c0 1.45.35 2.83.96 4.04l3.01-2.33Z" fill="#FBBC05" />
        <path d="M9 3.58c1.32 0 2.5.45 3.44 1.34l2.58-2.58A9 9 0 0 0 .96 4.96L3.97 7.3C4.68 5.16 6.66 3.58 9 3.58Z" fill="#EA4335" />
      </svg>
      <span>Continue with Google</span>
    </button>

    <p class="auth-switch">
      New to StudentLancers? <a href="/signup">Create an account</a>
    </p>
  </form>
</AuthLayout>

<script>
  import { mountAuthForms } from '../scripts/auth-form';
  mountAuthForms();
</script>

<style>
  /* Page-level overrides for tokenized link treatment */
  .auth-link {
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-line);
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .auth-link:hover {
    color: var(--color-link-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .auth-link:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }
</style>
