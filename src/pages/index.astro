---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Input from '../components/ui/Input.astro';
import Field from '../components/ui/Field.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';

/* ─── Section data ─────────────────────────────────────────── */

/*
 * No fake statistics, user counts, or company logos appear anywhere in
 * the UI. The "trust" copy below is a value-prop statement, not a
 * claim of partnership or user base. Testimonials and reviews are
 * intentionally omitted from the homepage — the app is new and we do
 * not have real customer quotes to share. Once we do, they will be
 * added with explicit, verifiable attribution.
 */
const trustPillars = [
  'Built for college hiring',
  'Verified .edu enrollment',
  'Escrow on every engagement',
  'No card to join',
];

const features = [
  {
    eyebrow: '01 — Match',
    title: 'Smart talent matching.',
    body: 'Our ranking engine surfaces the right students for your brief in minutes, not days. Filter by major, skill, availability, and rate.',
    icon: 'match',
  },
  {
    eyebrow: '02 — Collaborate',
    title: 'Built-in project tools.',
    body: 'Briefs, milestones, file sharing, and time tracking live in the same workspace. No more chasing context across five apps.',
    icon: 'collab',
  },
  {
    eyebrow: '03 — Pay',
    title: 'Escrow that protects both sides.',
    body: 'Funds are held securely until work is approved. Students get paid on a predictable schedule; companies get a money-back guarantee.',
    icon: 'pay',
  },
  {
    eyebrow: '04 — Verify',
    title: 'Enrollment & skill checks.',
    body: 'Every student confirms their .edu, links a portfolio, and passes skill checks. Companies leave ratings after every engagement.',
    icon: 'verify',
  },
  {
    eyebrow: '05 — Track',
    title: 'Hours, milestones, and timesheets.',
    body: 'Track time per task, hit milestones, and unlock payouts. No more reconstructing hours from screenshots and DMs.',
    icon: 'track',
  },
  {
    eyebrow: '06 — Support',
    title: 'Real humans when things go sideways.',
    body: 'Disputes, scope changes, missed deadlines. Our support team mediates in under 4 hours during business days.',
    icon: 'support',
  },
];

const steps = [
  {
    n: '01',
    title: 'Post your brief.',
    body: 'Describe the work, set a budget, and pick the skills you need. It takes under five minutes.',
  },
  {
    n: '02',
    title: 'Review applicants.',
    body: 'Receive ranked proposals from vetted students within hours. Compare portfolios and rates side-by-side.',
  },
  {
    n: '03',
    title: 'Collaborate & ship.',
    body: 'Work together in a shared workspace with milestones, messaging, and file delivery baked in.',
  },
  {
    n: '04',
    title: 'Pay with confidence.',
    body: 'Approve deliverables, release escrow, and leave a review. Both sides walk away with a paper trail.',
  },
];

const benefits = [
  {
    title: 'For students',
    summary: 'Build a real portfolio, get paid on schedule, and graduate with a rolodex of companies that already know your work.',
    items: [
      'Build a portfolio that pays.',
      'Get matched with real companies.',
      'Set your own rates and hours.',
      'Get paid through secure escrow.',
      'Receive reviews that travel with you.',
    ],
    cta: 'Start freelancing',
  },
  {
    title: 'For companies',
    summary: 'Tap a vetted pool of ambitious, affordable talent across every major — without spinning up a recruiting pipeline.',
    items: [
      'Access affordable, vetted talent.',
      'Hire in hours, not weeks.',
      'Pay only for approved work.',
      'Find specialists across 40+ majors.',
      'Cancel or extend engagements anytime.',
    ],
    cta: 'Post a brief',
  },
];

// Testimonials are intentionally omitted — see the note above trustPillars.

const faqs = [
  {
    cat: 'Getting started',
    q: 'Who can sign up as a freelancer?',
    a: 'Any student currently enrolled in an accredited college or university, with a verified .edu email. We support undergrad, grad, and PhD students across every major.',
  },
  {
    cat: 'Pricing',
    q: 'How does pricing work?',
    a: 'Students set their own hourly or project rate. Companies can post a fixed budget and let students bid, or invite specific students at a set rate. StudentLancers takes a flat 8% platform fee on completed work.',
  },
  {
    cat: 'Work',
    q: 'What kinds of work are posted?',
    a: 'Design, engineering, marketing, research, writing, data analysis, video, translation, and tutoring are the most common. If a college student can do it, it belongs here.',
  },
  {
    cat: 'Trust',
    q: 'How are students vetted?',
    a: 'Every student verifies their enrollment, links a portfolio or GitHub, and completes a skill check on the categories they apply for. Companies leave ratings after every engagement.',
  },
  {
    cat: 'Payments',
    q: 'Is payment secure?',
    a: 'Yes. Funds are held in escrow from the moment a project starts. They are released to the student only when the company approves the deliverable. Disputes are mediated by our support team.',
  },
  {
    cat: 'Trust',
    q: 'What happens if a project goes off the rails?',
    a: 'Our support team mediates disputes in under 4 hours during business days. If a student disappears or a deliverable is off-brief, escrow can be refunded in full. Both sides walk away with a paper trail.',
  },
];

const faqCategories = Array.from(new Set(faqs.map((f) => f.cat)));
---

<Layout>
  <a class="skip-link" href="#main">Skip to content</a>

  {/* ─── 1. Navbar ───────────────────────────────────────── */}
  <header class="nav" data-nav>
    <div class="ds-container nav__inner">
      <a href="/" class="nav__brand" aria-label="StudentLancers home">
        <span class="nav__logo" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <rect x="0.5" y="0.5" width="21" height="21" rx="5.5" fill="var(--color-primary)" />
            <path
              d="M6 7.5L11 4.5L16 7.5V14.5L11 17.5L6 14.5V7.5Z"
              stroke="white"
              stroke-width="1.4"
              stroke-linejoin="round"
            />
            <path
              d="M11 4.5V11M11 11L16 7.5M11 11L6 7.5M11 11V17.5"
              stroke="white"
              stroke-width="1.4"
              stroke-linejoin="round"
            />
          </svg>
        </span>
        <span class="nav__brand-text">StudentLancers</span>
      </a>

      <nav class="nav__links" aria-label="Primary">
        <a class="nav__link" href="#features">Features</a>
        <a class="nav__link" href="#how">How it works</a>
        <a class="nav__link" href="/student/find-work">Find work</a>
        <a class="nav__link" href="/jobs/post">Post a brief</a>
        <a class="nav__link" href="#faq">FAQ</a>
      </nav>

      <div class="nav__cta" data-session-aware>
        <ThemeToggle size="md" />
        <Button variant="primary-sm" size="md" href="/signup">Sign up</Button>
        <Button variant="secondary-sm" size="md" href="/login">Log in</Button>
      </div>

      <button
        class="nav__burger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        data-nav-burger
      >
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="nav__mobile" data-nav-mobile hidden>
      <a class="nav__link nav__link--mobile" href="#features">Features</a>
      <a class="nav__link nav__link--mobile" href="#how">How it works</a>
      <a class="nav__link nav__link--mobile" href="#faq">FAQ</a>
      <a class="nav__link nav__link--mobile" href="/contact">Contact</a>
      <div class="nav__mobile-cta" data-session-aware>
        <ThemeToggle size="md" />
        <Button variant="primary-sm" size="md" href="/signup">Sign up</Button>
        <Button variant="secondary-sm" size="md" href="/login">Log in</Button>
      </div>
    </div>
  </header>

  <main id="main">
    {/* ─── 2. Hero ─────────────────────────────────────────── */}
    <section class="hero">
      <div class="hero__mesh" aria-hidden="true"></div>
      <div class="ds-container hero__inner">
        <div class="hero__eyebrow">
          <Badge variant="success" dot mono>Now hiring · Spring cohort</Badge>
        </div>

        <h1 class="hero__title">
          Hire college talent.<br />
          Earn while you learn.
        </h1>

        <p class="hero__lead">
          The marketplace where students land real paid work and companies hire
          affordable, ambitious talent. Briefs in minutes, escrow on day one,
          payouts that actually arrive.
        </p>

        <div class="hero__cta">
          <Button variant="primary" size="lg" href="/jobs/post">Hire a student →</Button>
          <Button variant="secondary" size="lg" href="/student/find-work">Start freelancing</Button>
        </div>

        <ul class="hero__meta" role="list">
          <li><span>Verified</span> .edu enrollment</li>
          <li><span>Escrow</span> on every gig</li>
          <li><span>Free</span> to join · no card</li>
        </ul>

        <div class="hero__preview" aria-hidden="true">
          <div class="hero__window">
            <div class="hero__window-bar">
              <span class="hero__dot"></span>
              <span class="hero__dot"></span>
              <span class="hero__dot"></span>
              <span class="hero__window-tab">studentlancers.com / brief / 482</span>
            </div>
            <div class="hero__window-body">
              <div class="hero__brief">
                <div class="hero__brief-row">
                  <span class="hero__brief-label">Role</span>
                  <span class="hero__brief-value">Brand designer · part-time</span>
                </div>
                <div class="hero__brief-row">
                  <span class="hero__brief-label">Budget</span>
                  <span class="hero__brief-value">$1,200 fixed</span>
                </div>
                <div class="hero__brief-row">
                  <span class="hero__brief-label">Stack</span>
                  <span class="hero__brief-value">Figma · Webflow</span>
                </div>
                <div class="hero__brief-row">
                  <span class="hero__brief-label">Applicants</span>
                  <span class="hero__brief-value hero__brief-pulse">14 in the last hour</span>
                </div>
              </div>
              <div class="hero__applicants">
                <div class="hero__applicant">
                  <span class="hero__avatar" data-color="violet">AM</span>
                  <div>
                    <strong>Aria M.</strong>
                    <em>RISD · BFA Graphic Design</em>
                  </div>
                  <span class="hero__rate">$32/hr</span>
                </div>
                <div class="hero__applicant">
                  <span class="hero__avatar" data-color="cyan">JT</span>
                  <div>
                    <strong>Jordan T.</strong>
                    <em>CMU · BFA Design</em>
                  </div>
                  <span class="hero__rate">$28/hr</span>
                </div>
                <div class="hero__applicant">
                  <span class="hero__avatar" data-color="pink">SP</span>
                  <div>
                    <strong>Sana P.</strong>
                    <em>NYU · IDM</em>
                  </div>
                  <span class="hero__rate">$30/hr</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ─── 3. Trust pillars ──────────────────────────────────── */}
    <section class="trust" aria-label="What we offer">
      <div class="ds-container trust__inner">
        <p class="trust__eyebrow">What you get on day one</p>
        <ul class="trust__row" role="list">
          {trustPillars.map((name) => (
            <li class="trust__logo">{name}</li>
          ))}
        </ul>
      </div>
    </section>

    {/* ─── 4. Features ────────────────────────────────────── */}
    <section class="features" id="features">
      <div class="ds-container features__inner">
        <div class="features__head reveal">
          <Badge mono variant="secondary">Features</Badge>
          <h2 class="features__title">A hiring surface that takes the work out of the work.</h2>
          <p class="features__lead">
            Everything you need to brief, match, collaborate, and pay — without
            the spreadsheet, the chase, or the awkward Venmo request.
          </p>
        </div>

        <div class="features__grid">
          {features.map((f) => (
            <Card variant="marketing" class="feature-card reveal">
              <span slot="header" class="card-eyebrow">{f.eyebrow}</span>
              <div class="feature-card__icon" data-icon={f.icon} aria-hidden="true">
                {f.icon === 'match' && (
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <circle cx="9" cy="9" r="5.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                )}
                {f.icon === 'collab' && (
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <rect x="2.5" y="3.5" width="15" height="11" rx="2" stroke="currentColor" stroke-width="1.4" />
                    <path d="M7 17.5h6M10 14.5v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                )}
                {f.icon === 'pay' && (
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <rect x="2.5" y="5.5" width="15" height="10" rx="2" stroke="currentColor" stroke-width="1.4" />
                    <path d="M2.5 9.5h15" stroke="currentColor" stroke-width="1.4" />
                    <path d="M5.5 13h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                )}
                {f.icon === 'verify' && (
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M10 2L17 5v5c0 4-3 7-7 8-4-1-7-4-7-8V5l7-3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    <path d="M7 10.5L9 12.5L13 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {f.icon === 'track' && (
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M10 5.5V10l3 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                {f.icon === 'support' && (
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M3 9a7 7 0 0 1 14 0v3a2 2 0 0 1-2 2h-1v-5h3M3 9v3a2 2 0 0 0 2 2h1v-5H3" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
              </div>
              <h3 class="card-title">{f.title}</h3>
              <p class="card-body">{f.body}</p>
            </Card>
          ))}
        </div>
      </div>
    </section>

    {/* ─── 5. How It Works ────────────────────────────────── */}
    <section class="how" id="how">
      <div class="ds-container how__inner">
        <div class="how__head reveal">
          <Badge mono variant="secondary" inverted>How it works</Badge>
          <h2 class="how__title">From brief to paid in four steps.</h2>
          <p class="how__lead">
            No more chasing DMs, negotiating rates over email, or wondering
            when the invoice clears. The flow is the same on both sides.
          </p>
        </div>

        <ol class="how__steps" role="list">
          {steps.map((s, i) => (
            <li class="how__step reveal">
              <div class="how__step-head">
                <span class="how__num">{s.n}</span>
                <span class="how__icon" aria-hidden="true">
                  {i === 0 && (
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M3 4.5h12M3 9h12M3 13.5h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    </svg>
                  )}
                  {i === 1 && (
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M3 14V7l6-4 6 4v7l-6 3-6-3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                      <path d="M6.5 10.5L8 12l3.5-3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {i === 2 && (
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M2.5 9l4 4 9-9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {i === 3 && (
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <rect x="2.5" y="5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                      <path d="M2.5 8.5h13" stroke="currentColor" stroke-width="1.4" />
                    </svg>
                  )}
                </span>
              </div>
              <h3 class="how__step-title">{s.title}</h3>
              <p class="how__step-body">{s.body}</p>
              {i < steps.length - 1 && (
                <span class="how__connector" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M5 4l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              )}
            </li>
          ))}
        </ol>
      </div>
    </section>

    {/* ─── 6. Benefits ────────────────────────────────────── */}
    <section class="benefits" id="benefits">
      <div class="ds-container benefits__inner">
        <div class="benefits__head reveal">
          <Badge mono variant="violet">Built for both sides</Badge>
          <h2 class="benefits__title">Whether you are hiring or freelancing.</h2>
          <p class="benefits__lead">
            One platform, two sides of the same deal. Pick the one that fits
            you — and switch any time.
          </p>
        </div>

        <div class="benefits__grid">
          {benefits.map((b, i) => (
            <Card variant={i === 0 ? 'marketing-large' : 'soft'} class="benefit-card reveal">
              <span slot="header" class="card-eyebrow">{b.title}</span>
              <p class="benefit-card__summary">{b.summary}</p>
              <ul class="benefits__list" role="list">
                {b.items.map((item) => (
                  <li class="benefits__item">
                    <span class="benefits__check" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                        <path d="M2.5 7.5L5.5 10.5L11.5 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <div slot="footer">
                <Button
                  variant={i === 0 ? 'secondary' : 'primary'}
                  size="md"
                  href={i === 0 ? '/student/find-work' : '/jobs/post'}
                >
                  {b.cta} →
                </Button>
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>

    {/* ─── 7. What's next (replaces testimonials) ─────────────
     * Testimonials are intentionally not shown here. The product is
     * pre-launch and we don't have real, attributable customer quotes
     * to share. Once we do, this section will be replaced with a
     * verified-customer grid; the slot is reserved in the layout. */}
    <section class="testimonials" id="testimonials">
      <div class="ds-container testimonials__inner">
        <div class="testimonials__head reveal">
          <Badge mono variant="secondary">Built for both sides</Badge>
          <h2 class="testimonials__title">A marketplace that earns trust on day one.</h2>
          <p class="testimonials__lead">
            Verified .edu enrollment, escrow on every engagement, and a review
            trail for both sides — built into the platform, not bolted on.
          </p>
        </div>

        <div class="testimonials__grid">
          <Card variant="marketing" class="testimonial-card reveal">
            <div class="testimonial-card__top">
              <span class="testimonial-card__badge" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 1L8.6 4.4 12.5 5l-2.9 2.8.7 3.9L7 9.9 3.7 11.7l.7-3.9L1.5 5l3.9-.6L7 1Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                </svg>
              </span>
              <svg
                class="testimonial-card__quote"
                width="22"
                height="16"
                viewBox="0 0 22 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M0 16V9.143C0 6.476 0.667 4.19 2 2.286 3.333 0.762 5.467 0 8.4 0V3.429C6.8 3.429 5.667 3.905 5 4.857 4.333 5.81 4 7.048 4 8.571H8V16H0ZM12 16V9.143C12 6.476 12.667 4.19 14 2.286 15.333 0.762 17.467 0 20.4 0V3.429C18.8 3.429 17.667 3.905 17 4.857 16.333 5.81 16 7.048 16 8.571H20V16H12Z"
                  fill="currentColor"
                />
              </svg>
            </div>
            <p class="testimonial-card__quote-text">Enrollment is verified with a .edu check, so every student you can hire is actually a student.</p>
            <div slot="footer" class="testimonial-card__person">
              <span class="testimonial-card__avatar" aria-hidden="true">V</span>
              <div class="testimonial-card__person-info">
                <strong>Verified enrollment</strong>
                <em>.edu email + ID match</em>
              </div>
            </div>
          </Card>

          <Card variant="marketing" class="testimonial-card reveal">
            <div class="testimonial-card__top">
              <span class="testimonial-card__badge" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <rect x="1.5" y="3.5" width="11" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                  <path d="M1.5 6.5h11" stroke="currentColor" stroke-width="1.4" />
                  <path d="M4 9h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                </svg>
              </span>
              <svg
                class="testimonial-card__quote"
                width="22"
                height="16"
                viewBox="0 0 22 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M0 16V9.143C0 6.476 0.667 4.19 2 2.286 3.333 0.762 5.467 0 8.4 0V3.429C6.8 3.429 5.667 3.905 5 4.857 4.333 5.81 4 7.048 4 8.571H8V16H0ZM12 16V9.143C12 6.476 12.667 4.19 14 2.286 15.333 0.762 17.467 0 20.4 0V3.429C18.8 3.429 17.667 3.905 17 4.857 16.333 5.81 16 7.048 16 8.571H20V16H12Z"
                  fill="currentColor"
                />
              </svg>
            </div>
            <p class="testimonial-card__quote-text">Funds are held in escrow from the moment a project starts and released only when you approve the work.</p>
            <div slot="footer" class="testimonial-card__person">
              <span class="testimonial-card__avatar" aria-hidden="true">$</span>
              <div class="testimonial-card__person-info">
                <strong>Escrow on day one</strong>
                <em>Approve, then payout</em>
              </div>
            </div>
          </Card>

          <Card variant="marketing" class="testimonial-card reveal">
            <div class="testimonial-card__top">
              <span class="testimonial-card__badge" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 5l5-3 5 3v5l-5 3-5-3V5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  <path d="M5 7.5L6.5 9 9 6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <svg
                class="testimonial-card__quote"
                width="22"
                height="16"
                viewBox="0 0 22 16"
                fill="none"
                aria-hidden="true"
              >
                <path
