<style>
  /* ─── Shared helpers ─────────────────────────────────── */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 16px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    font-size: var(--text-body-sm);
    z-index: 100;
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 16px;
  }

  .card-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-mute);
  }

  .card-title {
    font-size: var(--text-display-sm);
    line-height: var(--text-display-sm-line);
    font-weight: var(--text-display-sm-weight);
    letter-spacing: var(--text-display-sm-tracking);
    color: var(--color-ink);
    margin: 0;
  }

  .card-body {
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    color: var(--color-body);
    margin: 0;
  }

  .link-inline {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .link-inline:hover {
    color: var(--color-link-deep);
  }

  /* ─── Animations: scroll-reveal + hover polish ─────────── */
  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    will-change: opacity, transform;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .hero__mesh,
    .cta__card-glow {
      animation: none !important;
    }
  }

  @keyframes float-slow {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -4px, 0); }
  }

  /* ─── 1. Navbar ──────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.78);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--color-hairline);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-lg);
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-ink);
  }

  .nav__brand-text {
    font-size: var(--text-body-md-strong);
    font-weight: var(--text-body-md-strong-weight);
    letter-spacing: -0.4px;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-line);
    color: var(--color-body);
    border-radius: var(--radius-full);
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav__link:hover {
    color: var(--color-ink);
    background-color: var(--color-canvas-soft);
  }

  .nav__cta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav__burger {
    display: none;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    cursor: pointer;
  }
  .nav__burger span {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--color-ink);
    border-radius: 2px;
  }

  .nav__mobile {
    display: none;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
  }
  .nav__mobile[hidden] {
    display: none;
  }
  .nav__link--mobile {
    width: 100%;
    padding: var(--space-sm);
    border-radius: var(--radius-sm);
  }
  .nav__mobile-cta {
    display: flex;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
  }
  .nav__mobile-cta :global(.ds-btn) {
    flex: 1;
  }

  @media (max-width: 900px) {
    .nav__links {
      display: none;
    }
    .nav__cta {
      display: none;
    }
    .nav__burger {
      display: inline-flex;
    }
    .nav__mobile {
      display: flex;
    }
  }

  /* ─── 2. Hero ────────────────────────────────────────── */
  .hero {
    position: relative;
    padding: var(--space-5xl) 0 var(--space-4xl);
    overflow: hidden;
    background: var(--color-canvas);
  }

  .hero__mesh {
    position: absolute;
    inset: -10% -5% 30% -5%;
    background: var(--gradient-brand);
    filter: blur(40px) saturate(110%);
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
  }
  .hero__mesh::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, var(--color-canvas) 92%);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    font-size: clamp(40px, 6vw, var(--text-display-xl));
    line-height: 1.04;
    font-weight: var(--text-display-xl-weight);
    letter-spacing: -2px;
    color: var(--color-ink);
    max-width: 880px;
    margin: 0;
  }

  .hero__lead {
    margin-top: var(--space-lg);
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg-line);
    color: var(--color-body);
    max-width: 640px;
  }

  .hero__cta {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .hero__meta {
    margin: var(--space-2xl) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    justify-content: center;
    color: var(--color-mute);
    font-size: var(--text-body-sm);
  }
  .hero__meta span {
    color: var(--color-ink);
    font-weight: var(--text-body-sm-strong-weight);
    margin-right: 4px;
  }

  /* Hero preview card */
  .hero__preview {
    margin-top: var(--space-3xl);
    width: 100%;
    max-width: 720px;
  }

  .hero__window {
    background: var(--color-canvas);
    border-radius: var(--radius-lg);
    box-shadow:
      0px 24px 64px -16px rgba(0, 0, 0, 0.18),
      0px 8px 24px -8px rgba(0, 0, 0, 0.08),
      inset 0 0 0 1px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    text-align: left;
  }

  .hero__window-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 14px;
    background: var(--color-canvas-soft);
    border-bottom: 1px solid var(--color-hairline);
  }
  .hero__dot {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    background: var(--color-hairline-strong);
  }
  .hero__window-tab {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-mute);
  }

  .hero__window-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .hero__brief {
    padding: var(--space-lg);
    border-right: 1px solid var(--color-hairline);
  }
  .hero__brief-row {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px dashed var(--color-hairline);
    font-size: var(--text-body-sm);
  }
  .hero__brief-row:last-child {
    border-bottom: 0;
  }
  .hero__brief-label {
    color: var(--color-mute);
  }
  .hero__brief-value {
    color: var(--color-ink);
    font-weight: var(--text-body-sm-strong-weight);
  }
  .hero__brief-pulse {
    color: var(--color-link);
    position: relative;
    padding-left: 10px;
  }
  .hero__brief-pulse::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-link);
    box-shadow: 0 0 0 4px var(--color-link-bg-soft);
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: translateY(-50%) scale(1); }
    50% { opacity: 0.6; transform: translateY(-50%) scale(0.85); }
  }

  .hero__applicants {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .hero__applicant {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px;
    border-radius: var(--radius-md);
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
  }
  .hero__applicant > div {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .hero__applicant strong {
    font-size: var(--text-body-sm-strong);
    font-weight: var(--text-body-sm-strong-weight);
    color: var(--color-ink);
  }
  .hero__applicant em {
    font-style: normal;
    font-size: var(--text-caption);
    color: var(--color-mute);
  }
  .hero__avatar {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-caption);
    font-weight: var(--text-body-sm-strong-weight);
    color: var(--color-on-primary);
    background: var(--color-primary);
  }
  .hero__avatar[data-color="violet"] { background: var(--color-violet); }
  .hero__avatar[data-color="cyan"] { background: var(--color-cyan-deep); }
  .hero__avatar[data-color="pink"] { background: var(--color-highlight-magenta); }
  .hero__rate {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-ink);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    padding: 4px 8px;
    border-radius: var(--radius-full);
  }

  @media (max-width: 600px) {
    .hero {
      padding: var(--space-4xl) 0 var(--space-3xl);
    }
    .hero__window-body {
      grid-template-columns: 1fr;
    }
    .hero__brief {
      border-right: 0;
      border-bottom: 1px solid var(--color-hairline);
    }
  }

  /* ─── 3. Trusted By ──────────────────────────────────── */
  .trust {
    background: var(--color-canvas-soft);
    border-block: 1px solid var(--color-hairline);
    padding: var(--space-2xl) 0;
  }
  .trust__inner {
    text-align: center;
  }
  .trust__eyebrow {
    font-size: var(--text-caption);
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family: var(--font-mono);
    margin: 0 0 var(--space-lg);
  }
  .trust__row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xl) var(--space-3xl);
    justify-content: center;
    align-items: center;
    list-style: none;
  }
  .trust__logo {
    font-family: var(--font-sans);
    font-size: var(--text-body-md);
    font-weight: var(--text-display-sm-weight);
    color: var(--color-mute);
    letter-spacing: -0.4px;
    opacity: 0.85;
    transition: color 0.15s ease, opacity 0.15s ease;
  }
  .trust__logo:hover {
    color: var(--color-ink);
    opacity: 1;
  }

  /* ─── 4. Features ────────────────────────────────────── */
  .features {
    background: var(--color-canvas);
    padding: var(--space-5xl) 0;
  }
  .features__head {
    max-width: 720px;
    margin-bottom: var(--space-3xl);
  }
  .features__head :global(.ds-badge) {
    margin-bottom: var(--space-md);
  }
  .features__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-ink);
    margin: 0 0 var(--space-md);
  }
  .features__lead {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg-line);
    color: var(--color-body);
    margin: 0;
  }
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  @media (max-width: 1100px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 700px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-card :global(.ds-card__body) {
    gap: var(--space-md);
  }
  .feature-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--color-canvas-soft);
    color: var(--color-ink);
    border: 1px solid var(--color-hairline);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }
  .feature-card:hover .feature-card__icon {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    transform: rotate(-4deg) scale(1.05);
  }
  .feature-card[data-icon] :global(.ds-card) { /* placeholder so future per-icon theming can hook in */ }

  /* ─── 5. How It Works ────────────────────────────────── */
  .how {
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: var(--space-5xl) 0;
  }
  .how__head {
    max-width: 720px;
    margin-bottom: var(--space-3xl);
  }
  .how__head :global(.ds-badge) {
    margin-bottom: var(--space-md);
  }
  .how__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-on-primary);
    margin: 0 0 var(--space-md);
  }
  .how__lead {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg-line);
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
  .how__steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    position: relative;
  }
  .how__step {
    position: relative;
    padding: var(--space-lg);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.04);
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .how__step:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
  }
  .how__step-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }
  .how__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.5);
  }
  .how__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-cyan);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .how__step-title {
    font-size: var(--text-display-sm);
    line-height: var(--text-display-sm-line);
    font-weight: var(--text-display-sm-weight);
    letter-spacing: var(--text-display-sm-tracking);
    color: var(--color-on-primary);
    margin: 0 0 var(--space-xs);
  }
  .how__step-body {
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-line);
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
  .how__connector {
    position: absolute;
    top: var(--space-lg);
    right: calc(var(--space-md) * -1 + 8px);
    width: calc(var(--space-md) - 8px);
    height: 32px;
    color: rgba(255, 255, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  @media (max-width: 1100px) {
    .how__steps {
      grid-template-columns: repeat(2, 1fr);
    }
    .how__connector {
      display: none;
    }
  }
  @media (max-width: 600px) {
    .how__steps {
      grid-template-columns: 1fr;
    }
  }

  /* ─── 6. Benefits ────────────────────────────────────── */
  .benefits {
    background: var(--color-canvas-soft);
    padding: var(--space-5xl) 0;
  }
  .benefits__head {
    max-width: 720px;
    margin-bottom: var(--space-3xl);
  }
  .benefits__head :global(.ds-badge) {
    margin-bottom: var(--space-md);
  }
  .benefits__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-ink);
    margin: 0 0 var(--space-md);
  }
  .benefits__lead {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg-line);
    color: var(--color-body);
    margin: 0;
  }
  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }
  @media (max-width: 800px) {
    .benefits__grid {
      grid-template-columns: 1fr;
    }
  }
  .benefits__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .benefits__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    color: inherit;
    transition: transform 0.15s ease;
  }
  .benefits__item:hover {
    transform: translateX(2px);
  }
  .benefits__check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-full);
    background: var(--color-cyan-soft);
    color: var(--color-cyan-deep);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
    transition: transform 0.2s ease;
  }
  .benefits__item:hover .benefits__check {
    transform: scale(1.1);
  }
  .benefits :global(.ds-card--soft) .benefits__check {
    background: var(--color-link-bg-soft);
    color: var(--color-link-deep);
  }

  .benefit-card :global(.ds-card__body) {
    gap: var(--space-md);
  }
  .benefit-card__summary {
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    color: var(--color-body);
    margin: 0;
  }
  .benefit-card :global(.ds-card--soft) .benefit-card__summary {
    color: var(--color-body);
  }

  /* ─── 7. Testimonials ────────────────────────────────── */
  .testimonials {
    background: var(--color-canvas);
    padding: var(--space-5xl) 0;
  }
  .testimonials__head {
    max-width: 720px;
    margin-bottom: var(--space-3xl);
  }
  .testimonials__head :global(.ds-badge) {
    margin-bottom: var(--space-md);
  }
  .testimonials__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-ink);
    margin: 0 0 var(--space-md);
  }
  .testimonials__lead {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg-line);
    color: var(--color-body);
    margin: 0;
  }
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  @media (max-width: 900px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
  .testimonials__quote {
    color: var(--color-hairline-strong);
    margin-bottom: var(--space-md);
  }
  .testimonial-card :global(.ds-card__body) {
    gap: var(--space-sm);
  }
  .testimonial-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .testimonial-card__rating {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    color: var(--color-warning);
  }
  .testimonial-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--color-canvas-soft);
    color: var(--color-ink);
    border: 1px solid var(--color-hairline);
  }
  .testimonial-card__quote {
    color: var(--color-hairline-strong);
  }
  .testimonial-card__quote-text {
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    color: var(--color-ink);
    margin: 0;
  }
  .testimonial-card__person {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .testimonial-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: var(--color-on-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-caption);
    font-weight: var(--text-body-sm-strong-weight);
    flex-shrink: 0;
  }
  .testimonial-card__person-info {
    flex: 1;
    min-width: 0;
  }
  .testimonial-card__person-info strong {
    display: block;
    font-size: var(--text-body-sm-strong);
    font-weight: var(--text-body-sm-strong-weight);
    color: var(--color-ink);
  }
  .testimonial-card__person-info em {
    display: block;
    font-style: normal;
    font-size: var(--text-caption);
    color: var(--color-mute);
  }
  .testimonial-card__company {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-body);
    padding: 4px 8px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-full);
    background: var(--color-canvas-soft);
  }

  /* ─── 8. FAQ ─────────────────────────────────────────── */
  .faq {
    background: var(--color-canvas-soft);
    padding: var(--space-5xl) 0;
  }
  .faq__head {
    max-width: 720px;
    margin-bottom: var(--space-3xl);
  }
  .faq__head :global(.ds-badge) {
    margin-bottom: var(--space-md);
  }
  .faq__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-ink);
    margin: 0 0 var(--space-md);
  }
  .faq__lead {
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    color: var(--color-body);
    margin: 0;
  }
  .faq__layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }
  .faq__nav {
    position: sticky;
    top: 80px;
  }
  .faq__nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .faq__tab {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-body);
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-line);
    text-align: left;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .faq__tab span {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-mute);
    background: var(--color-canvas-soft);
    padding: 2px 6px;
    border-radius: var(--radius-full);
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .faq__tab:hover {
    background: var(--color-canvas);
    color: var(--color-ink);
  }
  .faq__tab.is-active {
    background: var(--color-primary);
    color: var(--color-on-primary);
  }
  .faq__tab.is-active span {
    background: rgba(255, 255, 255, 0.15);
    color: var(--color-on-primary);
  }

  .faq__list {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .faq__item {
    border-bottom: 1px solid var(--color-hairline);
  }
  .faq__item:last-child {
    border-bottom: 0;
  }
  .faq__item.is-hidden {
    display: none;
  }
  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    color: var(--color-ink);
    list-style: none;
    transition: background-color 0.15s ease;
  }
  .faq__q::-webkit-details-marker {
    display: none;
  }
  .faq__q:hover {
    background: var(--color-canvas-soft);
  }
  .faq__q-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .faq__q-cat {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-mute);
  }
  .faq__q-title {
    font-size: var(--text-body-md);
    font-weight: var(--text-body-md-strong-weight);
    color: var(--color-ink);
  }
  .faq__icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-full);
    background: var(--color-canvas-soft);
    color: var(--color-body);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, color 0.15s ease;
  }
  .faq__item[open] .faq__icon {
    transform: rotate(180deg);
    background: var(--color-primary);
    color: var(--color-on-primary);
  }
  .faq__a {
    padding: 0 var(--space-lg) var(--space-lg);
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    color: var(--color-body);
    margin: 0;
  }

  @media (max-width: 800px) {
    .faq__layout {
      grid-template-columns: 1fr;
    }
    .faq__nav {
      position: static;
    }
    .faq__nav ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-xs);
    }
    .faq__tab {
      width: auto;
    }
  }

  /* ─── 9. CTA ─────────────────────────────────────────── */
  .cta {
    background: var(--color-canvas);
    padding: var(--space-5xl) 0;
  }
  .cta__card {
    position: relative;
    overflow: hidden;
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-radius: var(--radius-xl);
    padding: clamp(40px, 6vw, 72px);
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
    box-shadow:
      0px 24px 64px -16px rgba(0, 0, 0, 0.32),
      0px 8px 24px -8px rgba(0, 0, 0, 0.16),
      inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .cta__card-glow {
    position: absolute;
    inset: -30%;
    background: var(--gradient-brand);
    filter: blur(100px) saturate(130%);
    opacity: 0.45;
    pointer-events: none;
    z-index: 0;
    animation: cta-glow 18s ease-in-out infinite alternate;
  }
  @keyframes cta-glow {
    0% { transform: translate(-10%, -10%) scale(1); }
    100% { transform: translate(10%, 10%) scale(1.1); }
  }
  .cta__card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(23,23,23,0.45), rgba(23,23,23,0.88));
    pointer-events: none;
    z-index: 0;
  }
  .cta__copy,
  .cta__action {
    position: relative;
    z-index: 1;
  }
  .cta__copy :global(.ds-badge) {
    margin-bottom: var(--space-md);
  }
  .cta__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-on-primary);
    margin: 0 0 var(--space-md);
  }
  .cta__lead {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg-line);
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 var(--space-lg);
  }
  .cta__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin: 0;
  }
  .cta__bullets li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--text-body-sm);
  }
  .cta__bullet-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-cyan);
    box-shadow: 0 0 0 4px rgba(80, 227, 194, 0.15);
    flex-shrink: 0;
  }

  .cta__action {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .cta__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .cta__form :global(.ds-input) {
    background: var(--color-canvas);
  }
  .cta__fineprint {
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }
  .cta__fineprint a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cta__divider {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: rgba(255, 255, 255, 0.45);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .cta__divider::before,
  .cta__divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
  }
  .cta__alt {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .cta__alt :global(.ds-btn--secondary) {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-on-primary);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .cta__alt :global(.ds-btn--secondary):hover {
    background: rgba(255, 255, 255, 0.14);
  }
  .cta__alt :global(.ds-btn--ghost) {
    color: var(--color-on-primary);
  }
  .cta__alt :global(.ds-btn--ghost):hover {
    background: rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 800px) {
    .cta__form {
      flex-direction: row;
      align-items: stretch;
    }
    .cta__form :global(.ds-field) {
      flex: 1;
    }
    .cta__form :global(.ds-btn) {
      flex-shrink: 0;
    }
  }
  @media (max-width: 900px) {
    .cta__card {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  /* ─── 10. Footer ─────────────────────────────────────── */
  .footer {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: var(--space-4xl) 0 var(--space-xl);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
  }
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .footer__tagline {
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-line);
    color: var(--color-body);
    margin: 0;
    max-width: 280px;
  }
  .footer__socials {
    display: flex;
    gap: var(--space-xs);
  }
  .footer__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    color: var(--color-body);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .footer__icon-btn:hover {
    color: var(--color-ink);
    border-color: var(--color-hairline-strong);
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  .footer__col h4 {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-mute);
    font-weight: var(--text-body-sm-strong-weight);
    margin: 0 0 var(--space-md);
  }
  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .footer__col a {
    font-size: var(--text-body-sm);
    color: var(--color-body);
    transition: color 0.15s ease;
  }
  .footer__col a:hover {
    color: var(--color-ink);
  }
  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-hairline);
    font-size: var(--text-caption);
    color: var(--color-mute);
  }
  .footer__bottom p {
    margin: 0;
  }
  .footer__legal {
    list-style: none;
    display: flex;
    gap: var(--space-lg);
  }
  .footer__legal a {
