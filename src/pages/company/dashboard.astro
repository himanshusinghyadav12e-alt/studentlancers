---
import DashboardLayout, { type NavItem } from '../../layouts/DashboardLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import { listApplicationsForOwner, listJobsForOwner } from '../../lib/api';
import type { ApplicationWithJob, DbJob } from '../../lib/types';

/**
 * /company/dashboard
 *
 * The company side of the marketplace. Mirrors the student dashboard
 * structure — same primitives, no fake metrics. Lists show real
 * activity (briefs posted, applicants received) pulled from
 * public.jobs and public.applications.
 */

const companyNav: NavItem[] = [
  { href: '/company/dashboard', label: 'Overview', icon: 'home', current: true },
  { href: '/jobs/post', label: 'Post a brief', icon: 'brief' },
  { href: '/company/applicants', label: 'Applicants', icon: 'inbox' },
  { href: '/company/hires', label: 'Active hires', icon: 'gigs' },
  { href: '/company/billing', label: 'Billing', icon: 'wallet' },
  { href: '/company/profile', label: 'Company profile', icon: 'profile' },
  { href: '/company/settings', label: 'Settings', icon: 'settings' },
];

const user = Astro.locals.user;
const companyName = user?.name ?? 'Your company';
const greeting = user ? `Welcome back, ${companyName.split(' ')[0]}` : 'Welcome back';

let myBriefs: DbJob[] = [];
let appsForMine: ApplicationWithJob[] = [];
if (user && user.role === 'company') {
  try {
    [myBriefs, appsForMine] = await Promise.all([
      listJobsForOwner(Astro),
      listApplicationsForOwner(Astro),
    ]);
  } catch {
    // Render an empty dashboard; the page already shows zeros and
    // empty states when there is no data.
    myBriefs = [];
    appsForMine = [];
  }
}
const openBriefsCount = myBriefs.length;
const applicantsCount = appsForMine.length;
const activeHiresCount = appsForMine.filter((a) => a.status === 'hired').length;
const recentBriefs = myBriefs.slice(0, 3);
---

<DashboardLayout
  title="Dashboard · StudentLancers"
  description="Your StudentLancers company dashboard."
  name={companyName}
  role="Company"
  nav={companyNav}
>
  <header class="dash-page-head">
    <div class="dash-page-head__copy">
      <span class="dash-page-head__eyebrow">{greeting}</span>
      <h1 class="dash-page-head__title">Hire the next student on your team.</h1>
      <p class="dash-page-head__lead">
        Post a brief in under five minutes, review ranked applicants, and start
        a paid engagement on your own terms.
      </p>
    </div>
    <div class="dash-page-head__actions">
      <Button variant="primary" size="md" href="/jobs/post">Post a brief →</Button>
      <Button variant="secondary" size="md" href="/student/find-work">Browse talent</Button>
    </div>
  </header>

  <section aria-label="At a glance">
    <div class="dash-stats">
      <div class="dash-stat">
        <span class="dash-stat__label">Open briefs</span>
        <span class={`dash-stat__value ${openBriefsCount === 0 ? 'dash-stat__value--placeholder' : ''}`}>
          {openBriefsCount === 0 ? '—' : openBriefsCount}
        </span>
        <span class="dash-stat__hint">{openBriefsCount === 0 ? 'Post one to get started' : 'Live on the marketplace'}</span>
      </div>
      <div class="dash-stat">
        <span class="dash-stat__label">Applicants to review</span>
        <span class={`dash-stat__value ${applicantsCount === 0 ? 'dash-stat__value--placeholder' : ''}`}>
          {applicantsCount === 0 ? '—' : applicantsCount}
        </span>
        <span class="dash-stat__hint">{applicantsCount === 0 ? 'Awaiting your first brief' : 'Ranked proposals in your inbox'}</span>
      </div>
      <div class="dash-stat">
        <span class="dash-stat__label">Active hires</span>
        {activeHiresCount === 0 ? (
          <>
            <span class="dash-stat__value dash-stat__value--placeholder">—</span>
            <span class="dash-stat__hint">Hire from the applicants inbox</span>
          </>
        ) : (
          <a class="dash-stat__link" href="/company/hires" aria-label={`View ${activeHiresCount} active hires`}>
            <span class="dash-stat__value">{activeHiresCount}</span>
            <span class="dash-stat__hint dash-stat__hint--link">View active hires →</span>
          </a>
        )}
      </div>
      <div class="dash-stat">
        <span class="dash-stat__label">In flight</span>
        <span class="dash-stat__value dash-stat__value--placeholder">$0.00</span>
        <span class="dash-stat__hint">Active engagement spend</span>
      </div>
    </div>
  </section>

  <section class="dash-row" aria-label="Briefs and applicants">
    <div class="dash-card">
      <div class="dash-card__head">
        <h2 class="dash-card__title">Your briefs</h2>
        <Badge mono variant="secondary">{openBriefsCount === 0 ? 'Empty' : `${openBriefsCount} live`}</Badge>
      </div>
      <div class="dash-card__body">
        {recentBriefs.length === 0 ? (
          <div class="dash-empty">
            <span class="dash-empty__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <rect x="4" y="5" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.5" />
                <path d="M8 3h8v4H8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M4 11h16" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </span>
            <h3 class="dash-empty__title">No briefs yet</h3>
            <p class="dash-empty__body">
              Post a brief to start receiving ranked proposals. Most briefs get
              their first applicant within a few hours.
            </p>
            <Button variant="primary" size="md" href="/jobs/post">Post your first brief →</Button>
          </div>
        ) : (
          <ul class="dash-list" role="list">
            {recentBriefs.map((b) => {
              const count = appsForMine.filter((a) => a.job_id === b.id).length;
              return (
                <li class="dash-list__item">
                  <span class="dash-list-avatar" data-color="link" aria-hidden="true">B</span>
                  <div class="dash-list__main">
                    <span class="dash-list__title">{b.title}</span>
                    <span class="dash-list__sub">{b.category} · {b.budget_type === 'fixed' ? `$${Math.round(b.budget_cents / 100).toLocaleString()} fixed` : `$${Math.round(b.budget_cents / 100)}/hr`}</span>
                  </div>
                  <Badge variant="cyan">{count} {count === 1 ? 'applicant' : 'applicants'}</Badge>
                </li>
              );
            })}
            <li class="dash-list__more">
              <a href="/company/applicants">See all applicants →</a>
            </li>
          </ul>
        )}
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card__head">
        <h2 class="dash-card__title">Top picks for you</h2>
        <Badge mono variant="violet">Preview</Badge>
      </div>
      <div class="dash-card__body">
        <p style="margin: 0; color: var(--color-body); font-size: var(--text-body-sm);">
          Once you post a brief, ranked applicants will appear here with their
          school, year, portfolio, and proposed rate. Until then, the system has
          nothing to rank.
        </p>
        <ul class="dash-list" role="list" style="opacity: 0.55;">
          <li class="dash-list__item">
            <span class="dash-list-avatar" data-color="ink" aria-hidden="true">·</span>
            <div class="dash-list__main">
              <span class="dash-list__title">Awaiting your first brief</span>
              <span class="dash-list__sub">Post one to see ranked matches</span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="dash-card" aria-label="Get started checklist">
    <div class="dash-card__head">
      <h2 class="dash-card__title">Get your company set up</h2>
      <Badge mono variant="cyan">Onboarding</Badge>
    </div>
    <div class="dash-card__body">
      <ul class="dash-list" role="list">
        <li class="dash-list__item">
          <span class="dash-list-avatar" data-color="link" aria-hidden="true">1</span>
          <div class="dash-list__main">
            <span class="dash-list__title">Verify your work email</span>
            <span class="dash-list__sub">Required before posting or messaging students</span>
          </div>
          <span class="dash-pill dash-pill--warning">Verify</span>
        </li>
        <li class="dash-list__item">
          <span class="dash-list-avatar" data-color="violet" aria-hidden="true">2</span>
          <div class="dash-list__main">
            <span class="dash-list__title">Add billing details</span>
            <span class="dash-list__sub">A card on file is needed to post paid briefs</span>
          </div>
          <span class="dash-pill dash-pill--warning">Add</span>
        </li>
        <li class="dash-list__item">
          <span class="dash-list-avatar" data-color="cyan" aria-hidden="true">3</span>
          <div class="dash-list__main">
            <span class="dash-list__title">Post your first brief</span>
            <span class="dash-list__sub">Takes about five minutes — title, budget, skills</span>
          </div>
          <Button variant="secondary" size="sm" href="/jobs/post">Start</Button>
        </li>
      </ul>
    </div>
  </section>
</DashboardLayout>

<style>
  .dash-list__more {
    list-style: none;
    padding: 8px 0 0;
    text-align: center;
    border-top: 1px solid var(--color-hairline);
  }
  .dash-list__more a {
    font-size: var(--text-body-sm);
    color: var(--color-link);
  }
</style>
