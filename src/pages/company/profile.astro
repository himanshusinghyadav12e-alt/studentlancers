---
import DashboardLayout, { type NavItem } from '../../layouts/DashboardLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Field from '../../components/ui/Field.astro';
import Input from '../../components/ui/Input.astro';
import SubPageShell from '../../components/SubPageShell.astro';
import BackLink from '../../components/ui/BackLink.astro';

/**
 * /company/profile
 *
 * Editor for the signed-in company's public profile. Renders the
 * current values as the form's default state, and a live preview
 * card next to the form so the user can see what students will see
 * before they save.
 *
 * The page degrades gracefully: if the visitor is not signed in, or
 * is signed in as a student, we render a friendly sign-in / wrong-
 * account prompt via SubPageShell instead of a half-broken form.
 */

const companyNav: NavItem[] = [
  { href: '/company/dashboard', label: 'Overview', icon: 'home' },
  { href: '/jobs/post', label: 'Post a brief', icon: 'brief' },
  { href: '/company/applicants', label: 'Applicants', icon: 'inbox' },
  { href: '/company/hires', label: 'Active hires', icon: 'gigs' },
  { href: '/company/billing', label: 'Billing', icon: 'wallet' },
  { href: '/company/profile', label: 'Company profile', icon: 'profile', current: true },
  { href: '/company/settings', label: 'Settings', icon: 'settings' },
];

const user = Astro.locals.user;
const session = Astro.locals.session;
const isCompany = user?.role === 'company';
// Astro.locals.companyProfile is populated by the middleware from
// public.company_profiles. Fall back to an empty record so the form
// renders placeholders on first run.
const profile = Astro.locals.companyProfile ?? ({} as NonNullable<typeof Astro.locals.companyProfile>);

// The shell prompt is shown for signed-out visitors and for students
// who wander to /company/profile via a stale link. The form path is
// only rendered for a signed-in company account.
const showShell = !isCompany;
const displayName = user?.name ?? 'Your company';
---

{
  showShell ? (
    <SubPageShell
      title="Company profile · StudentLancers"
      description="Edit the way your company appears to students."
      name={displayName}
      role="Company"
      nav={companyNav}
      eyebrow="Company profile"
      heading="Sign in as a company to edit your profile"
      body="This page edits the public profile of a company account. Sign in with the company account you used to post briefs, or create one to get started."
      ctaLabel={session ? 'Sign in' : 'Sign in'}
      ctaHref="/login"
      badge="Sign in required"
    />
  ) : (
    <DashboardLayout
      title="Company profile · StudentLancers"
      description="Edit the way your company appears to students."
      name={displayName}
      role="Company"
      nav={companyNav}
    >
      <header class="dash-page-head">
        <div class="dash-page-head__copy">
          <BackLink href="/company/dashboard" label="Back to overview" />
          <span class="dash-page-head__eyebrow">Company profile</span>
          <h1 class="dash-page-head__title">How students see you</h1>
          <p class="dash-page-head__lead">
            Your company profile shows up next to your briefs and on every
            applicant card. Profiles with a logo and a paragraph of context
            get more applications.
          </p>
        </div>
        <div class="dash-page-head__actions">
          <Badge mono variant="cyan">Synced to Supabase</Badge>
        </div>
      </header>

      <form
        class="prof"
        data-company-profile-form
        novalidate
        aria-label="Edit company profile"
      >
        <div
          class="prof__alert"
          data-form-alert
          role="alert"
          aria-live="polite"
          hidden
        >
          <strong data-form-alert-title>Please review the form.</strong>
          <span data-form-alert-msg></span>
        </div>

        <div class="prof__grid">
          <div class="prof__editor">
            <section class="dash-card" aria-labelledby="prof-identity">
              <div class="dash-card__head">
                <h2 class="dash-card__title" id="prof-identity">Identity</h2>
                <span class="dash-card__hint">Logo + web address</span>
              </div>
              <div class="dash-card__body">
                <Field
                  label="Logo URL"
                  for="prof-logo"
                  hint="Paste a link to a hosted image (PNG, SVG, or JPG). Leave blank to use a placeholder."
                >
                  <Input
                    type="url"
                    id="prof-logo"
                    name="logoUrl"
                    size="lg"
                    value={profile.logoUrl ?? ''}
                    placeholder="https://…/logo.png"
                    data-field="logoUrl"
                    autocomplete="off"
                  />
                </Field>
                <Field
                  label="Website"
                  for="prof-website"
                  hint="Your company home page. Students use this to verify you."
                >
                  <Input
                    type="url"
                    id="prof-website"
                    name="website"
                    size="lg"
                    value={profile.website ?? ''}
                    placeholder="https://example.com"
                    data-field="website"
                    autocomplete="url"
                  />
                </Field>
              </div>
            </section>

            <section class="dash-card" aria-labelledby="prof-about">
              <div class="dash-card__head">
                <h2 class="dash-card__title" id="prof-about">About</h2>
                <span class="dash-card__hint">40–600 characters</span>
              </div>
              <div class="dash-card__body">
                <Field
                  label="Blurb"
                  for="prof-blurb"
                  hint="One short paragraph. What do you build, who do you hire, and what kind of work lands well with your team."
                >
                  <Input
                    as="textarea"
                    id="prof-blurb"
                    name="blurb"
                    size="lg"
                    rows={5}
                    value={profile.blurb ?? ''}
                    placeholder="We build internal tools for B2B SaaS and hire one or two students per quarter for short, paid engagements."
                    data-field="blurb"
                  />
                </Field>
                <div class="prof__count" data-blurb-count>
                  {(profile.blurb ?? '').length} / 600
                </div>
              </div>
            </section>

            <div class="prof__actions">
              <Button variant="primary" size="lg" type="submit" data-submit>
                <span data-submit-label>Save profile</span>
              </Button>
              <span class="prof__saved" data-saved hidden>Saved.</span>
            </div>
          </div>

          <aside class="prof__preview" aria-label="Live preview">
            <span class="prof__preview-label">Preview</span>
            <article class="prof-card" data-profile-preview>
              <div class="prof-card__logo" data-preview-logo aria-hidden="true">
                <span data-preview-logo-text>
                  {displayName.split(' ').map((p) => p[0]).filter(Boolean).slice(0, 2).join('').toUpperCase() || '·'}
                </span>
              </div>
              <div class="prof-card__main">
                <h3 class="prof-card__name">{displayName}</h3>
                <a
                  class="prof-card__website"
                  href={profile.website || '#'}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-preview-website
                  data-empty={!profile.website ? 'true' : 'false'}
                >
                  {profile.website
                    ? (() => {
                        try {
                          return new URL(profile.website).host.replace(/^www\./, '');
                        } catch {
                          return profile.website;
                        }
                      })()
                    : 'example.com'}
                </a>
                <p class="prof-card__blurb" data-preview-blurb data-empty={!profile.blurb ? 'true' : 'false'}>
                  {profile.blurb || 'Add a short paragraph so students know what you build and who you hire. This is the first thing they read on your profile.'}
                </p>
              </div>
            </article>
            <p class="prof__preview-hint">
              The preview updates as you type. Students will see this on your
              briefs and on every applicant card.
            </p>
          </aside>
        </div>
      </form>
    </DashboardLayout>
  )
}

<style>
  .prof {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* Form-level error / info alert */
  .prof__alert {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-error-soft);
    color: var(--color-error-deep);
    border: 1px solid color-mix(in srgb, var(--color-error) 22%, transparent);
    border-radius: var(--radius-md);
    font-size: var(--text-body-sm);
  }
  .prof__alert strong {
    font-weight: var(--text-body-sm-strong-weight);
  }
  .prof__alert[hidden] {
    display: none;
  }

  .prof__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: start;
  }
  @media (max-width: 1000px) {
    .prof__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .prof__editor {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* Character counter for the blurb field */
  .prof__count {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-mute);
    text-align: right;
  }
  .prof__count[data-over='true'] {
    color: var(--color-error);
  }

  /* Save row */
  .prof__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }
  .prof__saved {
    font-size: var(--text-body-sm);
    color: var(--color-link-deep);
  }
  .prof__saved[hidden] {
    display: none;
  }

  /* Preview column */
  .prof__preview {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .prof__preview-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-mute);
  }
  .prof__preview-hint {
    margin: 0;
    font-size: var(--text-caption);
    color: var(--color-mute);
  }

  /* Profile preview card */
  .prof-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-level-1);
  }
  .prof-card__logo {
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--color-on-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: var(--text-body-md);
    font-weight: var(--text-body-md-strong-weight);
    letter-spacing: 0.04em;
    overflow: hidden;
  }
  .prof-card__logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
  .prof-card__main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .prof-card__name {
    margin: 0;
    font-size: var(--text-body-md);
    font-weight: var(--text-body-md-strong-weight);
    color: var(--color-ink);
  }
  .prof-card__website {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-link);
    text-decoration: none;
    word-break: break-all;
  }
  .prof-card__website:hover {
    text-decoration: underline;
  }
  .prof-card__website[data-empty='true'] {
    color: var(--color-mute);
    pointer-events: none;
    text-decoration: none;
  }
  .prof-card__blurb {
    margin: 6px 0 0;
    font-size: var(--text-body-sm);
    line-height: 1.55;
    color: var(--color-body);
  }
  .prof-card__blurb[data-empty='true'] {
    color: var(--color-mute);
    font-style: italic;
  }
</style>

<script>
  import { mountCompanyProfile } from '../../scripts/company-profile';
  mountCompanyProfile();
</script>
