---
import SubPageShell from '../../components/SubPageShell.astro';
import { store } from '../../scripts/store';
import type { NavItem } from '../../layouts/DashboardLayout.astro';

const nav: NavItem[] = [
  { href: '/company/dashboard', label: 'Overview', icon: 'home' },
  { href: '/jobs/post', label: 'Post a brief', icon: 'brief' },
  { href: '/company/applicants', label: 'Applicants', icon: 'inbox' },
  { href: '/company/hires', label: 'Active hires', icon: 'gigs' },
  { href: '/company/billing', label: 'Billing', icon: 'wallet' },
  { href: '/company/profile', label: 'Company profile', icon: 'profile', current: true },
  { href: '/company/settings', label: 'Settings', icon: 'settings' },
];
const session = store.auth.current();
const name = session?.name ?? 'Your company';
---
<SubPageShell
  title="Company profile · StudentLancers"
  description="Edit the way your company appears to students."
  name={name}
  role="Company"
  nav={nav}
  eyebrow="Company profile"
  heading="Your company profile"
  body="Add a logo, a short blurb, your website, and the team members students will work with. Profiles that include a logo and a paragraph of context get more applications, on average."
  ctaLabel="Post a brief"
  ctaHref="/jobs/post"
  badge="Onboarding"
/>
