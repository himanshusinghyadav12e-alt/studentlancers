---
import DashboardLayout, { type NavItem } from '../../layouts/DashboardLayout.astro';
import Button from '../../components/ui/Button.astro';
import SubPageShell from '../../components/SubPageShell.astro';
import BackLink from '../../components/ui/BackLink.astro';
import { listApplicationsForOwner, listJobsForOwner } from '../../lib/api';
import type { ApplicationStatus, DbJob } from '../../lib/types';

/**
 * /company/applicants
 *
 * Company inbox. Lists every application on the briefs the signed-in
 * company has posted, grouped by brief, with a status filter, a
 * per-applicant action row (Shortlist / Hire / Reject), and summary
 * counts in the header. Action buttons are wired by
 * src/scripts/applicants.ts, which PATCHes /api/applications and
 * updates the DOM in place — no full page reload.
 *
 * The page renders honest empty states at two levels: no applications
 * at all (SubPageShell) and a brief with zero applicants matching
 * the active filter (inline).
 */

const companyNav: NavItem[] = [
  { href: '/company/dashboard', label: 'Overview', icon: 'home' },
  { href: '/jobs/post', label: 'Post a brief', icon: 'brief' },
  { href: '/company/applicants', label: 'Applicants', icon: 'inbox', current: true },
  { href: '/company/hires', label: 'Active hires', icon: 'gigs' },
  { href: '/company/billing', label: 'Billing', icon: 'wallet' },
  { href: '/company/profile', label: 'Company profile', icon: 'profile' },
  { href: '/company/settings', label: 'Settings', icon: 'settings' },
];

const user = Astro.locals.user;
const companyName = user?.name ?? 'Your company';

let myBriefs: DbJob[] = [];
let apps: Awaited<ReturnType<typeof listApplicationsForOwner>> = [];
let loadError: string | null = null;
if (user && user.role === 'company') {
  try {
    [myBriefs, apps] = await Promise.all([
      listJobsForOwner(Astro),
      listApplicationsForOwner(Astro),
    ]);
  } catch (err) {
    loadError = err instanceof Error ? err.message : 'Could not load applicants.';
  }
}

// Group by brief. We sort briefs by most-recent activity (most recent
// application) so the inbox reads like an email thread, not a brief
// list.
const lastActivity = new Map<string, string>();
for (const a of apps) {
  const prev = lastActivity.get(a.job_id);
  if (!prev || a.created_at > prev) lastActivity.set(a.job_id, a.created_at);
}
const sortedBriefs = [...myBriefs].sort((a, b) => {
  const aa = lastActivity.get(a.id) ?? a.created_at;
  const bb = lastActivity.get(b.id) ?? b.created_at;
  return bb.localeCompare(aa);
});
const byBrief = sortedBriefs
  .map((b) => ({ brief: b, apps: apps.filter((a) => a.job_id === b.id) }))
  .filter((row) => row.apps.length > 0);

const counts = {
  total: apps.length,
  new: apps.filter((a) => a.status === 'new').length,
  shortlisted: apps.filter((a) => a.status === 'shortlisted').length,
  hired: apps.filter((a) => a.status === 'hired').length,
  rejected: apps.filter((a) => a.status === 'rejected').length,
};

const FILTERS: { value: 'all' | ApplicationStatus; label: string; pillClass?: string }[] = [
  { value: 'all', label: 'All' },
  { value: 'new', label: 'New', pillClass: 'dash-pill--cyan' },
  { value: 'shortlisted', label: 'Shortlisted', pillClass: 'dash-pill--violet' },
  { value: 'hired', label: 'Hired', pillClass: 'dash-pill--success' },
  { value: 'rejected', label: 'Rejected', pillClass: 'dash-pill--warning' },
];

const statusLabel: Record<ApplicationStatus, string> = {
  new: 'New',
  shortlisted: 'Shortlisted',
  hired: 'Hired',
  rejected: 'Rejected',
};

const statusPillClass: Record<ApplicationStatus, string> = {
  new: 'dash-pill dash-pill--cyan',
  shortlisted: 'dash-pill dash-pill--violet',
  hired: 'dash-pill dash-pill--success',
  rejected: 'dash-pill dash-pill--warning',
};
---

{
  byBrief.length === 0 ? (
    <SubPageShell
      title="Applicants · StudentLancers"
      description="Review ranked proposals on the briefs you have posted."
      name={companyName}
      role="Company"
      nav={companyNav}
      eyebrow="Applicants"
      heading={loadError ? 'We could not load applicants' : 'Review applicants'}
      body={
        loadError
          ? loadError
          : 'Ranked proposals land here once you post a brief. Until then, the inbox is empty.'
      }
      ctaLabel="Post your first brief"
      ctaHref="/jobs/post"
      badge={loadError ? 'Error' : 'Empty'}
    />
  ) : (
    <DashboardLayout
      title="Applicants · StudentLancers"
      description="Review ranked proposals on the briefs you have posted."
      name={companyName}
      role="Company"
      nav={companyNav}
    >
      <header class="dash-page-head">
        <div class="dash-page-head__copy">
          <BackLink href="/company/dashboard" label="Back to overview" />
          <span class="dash-page-head__eyebrow">Applicants</span>
          <h1 class="dash-page-head__title">Review ranked proposals</h1>
          <p class="dash-page-head__lead">
            {counts.total} {counts.total === 1 ? 'applicant' : 'applicants'} across {byBrief.length} {byBrief.length === 1 ? 'brief' : 'briefs'}.
            {counts.hired > 0 && (
              <>
                {' '}
                <span class={`apps__inline-stat ${statusPillClass.hired}`}>{counts.hired} hired</span>
              </>
            )}
          </p>
        </div>
        <div class="dash-page-head__actions">
          <Button variant="primary" size="md" href="/jobs/post">Post another brief</Button>
        </div>
      </header>

      <section class="apps-stats" aria-label="Status counts">
        {FILTERS.slice(1).map((f) => (
          <div class="apps-stats__cell">
            <span class="apps-stats__label">{f.label}</span>
            <span class="apps-stats__value">{counts[f.value as ApplicationStatus]}</span>
          </div>
        ))}
      </section>

      <section class="apps" aria-label="Applicants by brief" data-applicants-root>
        <div class="apps__filters" role="group" aria-label="Filter by status" data-applicants-filters>
          {FILTERS.map((f) => {
            const count =
              f.value === 'all' ? counts.total : counts[f.value as ApplicationStatus];
            return (
              <button
                type="button"
                class="dash-filters__chip"
                aria-pressed={f.value === 'all' ? 'true' : 'false'}
                data-filter={f.value}
              >
                <span>{f.label}</span>
                <span class="apps__chip-count" aria-hidden="true">{count}</span>
              </button>
            );
          })}
        </div>

        {byBrief.map(({ brief, apps }) => (
          <article class="apps__group" data-brief-id={brief.id}>
            <header class="apps__group-head">
              <div>
                <h2 class="apps__group-title">{brief.title}</h2>
                <span class="apps__group-meta">
                  {apps.length} {apps.length === 1 ? 'applicant' : 'applicants'} · {brief.budget_type === 'hourly' ? `$${Math.round(brief.budget_cents / 100)}/hr` : `$${Math.round(brief.budget_cents / 100)} fixed`}
                </span>
              </div>
              <a class="apps__brief-link" href={`/jobs/${brief.id}`} target="_blank" rel="noopener noreferrer">
                View brief →
              </a>
            </header>
            <ul class="apps__list" role="list" data-applicants-list>
              {apps.map((a) => (
                <li
                  class="apps__item"
                  id={`applicant-${a.id}`}
                  data-applicant-card
                  data-applicant-id={a.id}
                  data-applicant-status={a.status}
                >
                  <div class="apps__row">
                    <div class="apps__identity">
                      <span class="dash-list-avatar" aria-hidden="true" data-color={a.status === 'hired' ? 'link' : a.status === 'shortlisted' ? 'violet' : a.status === 'rejected' ? 'ink' : 'cyan'}>
                        {a.applicant.name.split(' ').map((p) => p[0]).filter(Boolean).slice(0, 2).join('').toUpperCase() || '·'}
                      </span>
                      <div class="apps__main">
                        <div class="apps__name">{a.applicant.name}</div>
                        <a class="apps__email" href={`mailto:${a.applicant.email}`}>{a.applicant.email}</a>
                      </div>
                    </div>
                    <div class="apps__numbers">
                      {a.rate_cents != null && (
                        <span class="apps__rate">${Math.round(a.rate_cents / 100)} <em>proposed</em></span>
                      )}
                      {a.timeline && <span class="apps__timeline">{a.timeline}</span>}
                    </div>
                    <div class="apps__status">
                      <span class={statusPillClass[a.status]} data-applicant-status-pill>
                        {statusLabel[a.status]}
                      </span>
                    </div>
                  </div>

                  <details class="apps__cover">
                    <summary>
                      <span class="apps__cover-toggle">Read full proposal</span>
                      <span class="apps__cover-excerpt">{a.cover.length > 140 ? `${a.cover.slice(0, 140).trimEnd()}…` : a.cover}</span>
                    </summary>
                    <p class="apps__cover-body">{a.cover}</p>
                  </details>

                  {a.portfolio_url && (
                    <div class="apps__foot">
                      <a class="apps__link" href={a.portfolio_url} target="_blank" rel="noopener noreferrer">View portfolio →</a>
                      <span class="apps__id">Application <code>{a.id.slice(0, 8)}</code></span>
                      <div class="apps__manage" data-applicant-manage>
                        <button
                          type="button"
                          class="ds-btn ds-btn--tab ds-btn--size-md"
                          aria-expanded="false"
                          data-manage-toggle
                          aria-controls={`manage-row-${a.id}`}
                        >
                          Manage
                        </button>
                        <div
                          class="apps__manage-row"
                          id={`manage-row-${a.id}`}
                          role="group"
                          aria-label={`Manage ${a.applicant.name}'s application`}
                          hidden
                        >
                          <button
                            type="button"
                            class="ds-btn ds-btn--ghost ds-btn--size-md"
                            data-action="shortlist"
                            data-applicant-id={a.id}
                          >
                            Shortlist
                          </button>
                          <button
                            type="button"
                            class="ds-btn ds-btn--primary-sm ds-btn--size-md"
                            data-action="hire"
                            data-applicant-id={a.id}
                          >
                            Hire
                          </button>
                          <button
                            type="button"
                            class="ds-btn ds-btn--ghost ds-btn--size-md apps__action-reject"
                            data-action="reject"
                            data-applicant-id={a.id}
                          >
                            Reject
                          </button>
                        </div>
                      </div>
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </section>
    </DashboardLayout>
  )
}

<style>
  .apps {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* ─── Header summary stats ────────────────────────────── */
  .apps-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-md);
  }
  @media (max-width: 800px) {
    .apps-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .apps-stats__cell {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-md) var(--space-lg);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-level-1);
  }
  .apps-stats__label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-mute);
  }
  .apps-stats__value {
    font-size: var(--text-display-md);
    line-height: var(--text-display-md-line);
    font-weight: var(--text-display-md-weight);
    letter-spacing: var(--text-display-md-tracking);
    color: var(--color-ink);
  }

  /* ─── Filter chips ────────────────────────────────────── */
  .apps__filters {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    padding: var(--space-md);
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
  }
  .apps__chip-count {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-mute);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-full);
    padding: 1px 8px;
    min-width: 24px;
    text-align: center;
  }
  .dash-filters__chip[aria-pressed='true'] .apps__chip-count {
    background: color-mix(in srgb, var(--color-on-primary) 18%, transparent);
    color: var(--color-on-primary);
    border-color: transparent;
  }

  /* ─── Inline stat next to total count in the header ─── */
  .apps__inline-stat {
    margin-left: var(--space-xs);
    vertical-align: middle;
  }

  /* ─── Per-brief group ────────────────────────────────── */
  .apps__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-level-1);
  }
  .apps__group-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .apps__group-title {
    margin: 0;
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    font-weight: var(--text-body-md-strong-weight);
    color: var(--color-ink);
  }
  .apps__group-meta {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-mute);
    margin-top: 2px;
  }
  .apps__brief-link {
    font-size: var(--text-body-sm);
    color: var(--color-link);
    text-decoration: none;
  }
  .apps__brief-link:hover {
    text-decoration: underline;
  }

  /* ─── Applicant card ─────────────────────────────────── */
  .apps__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .apps__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    transition: border-color 0.15s ease, opacity 0.2s ease;
  }
  .apps__item[data-applicant-status='rejected'] {
    opacity: 0.65;
  }
  .apps__item[data-applicant-status='hired'] {
    border-color: color-mix(in srgb, var(--color-link) 32%, var(--color-hairline));
    background: var(--color-link-bg-soft);
  }
  .apps__item.is-hidden {
    display: none;
  }

  /* Deep-link flash: when a card is the :target (the browser jumped
     to /company/applicants#applicant-{id} from /company/hires), give
     it a brief border + box-shadow pulse so the user sees where the
     page landed. The animation runs once and decays back to the
     card's resting style over ~2s. */
  @keyframes apps-target-flash {
    0% {
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-link) 28%, transparent);
      border-color: var(--color-link);
    }
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-link) 0%, transparent);
    }
  }
  .apps__item:target {
    animation: apps-target-flash 2s ease-out 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .apps__item:target {
      animation: none;
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-link) 18%, transparent);
    }
  }

  .apps__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .apps__identity {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    min-width: 0;
    flex: 1 1 220px;
  }
  .apps__main {
    min-width: 0;
  }
  .apps__name {
    font-size: var(--text-body-md);
    font-weight: var(--text-body-md-strong-weight);
    color: var(--color-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .apps__email {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-mute);
    text-decoration: none;
    display: inline-block;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .apps__email:hover {
    color: var(--color-link);
  }
  .apps__numbers {
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: flex-start;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-ink);
    flex: 0 0 auto;
  }
  .apps__rate em {
    font-style: normal;
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-left: 4px;
  }
  .apps__timeline {
    color: var(--color-mute);
  }
  .apps__status {
    flex: 0 0 auto;
  }

  /* ─── Cover letter (collapsible) ─────────────────────── */
  .apps__cover {
    border-top: 1px solid var(--color-hairline);
    padding-top: var(--space-sm);
  }
  .apps__cover > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .apps__cover > summary::-webkit-details-marker {
    display: none;
  }
  .apps__cover-toggle {
    font-size: var(--text-body-sm);
    font-weight: var(--text-body-sm-strong-weight);
    color: var(--color-link);
    flex-shrink: 0;
  }
  .apps__cover[open] .apps__cover-toggle::before {
    content: '− ';
  }
  .apps__cover:not([open]) .apps__cover-toggle::before {
    content: '+ ';
  }
  .apps__cover-excerpt {
    font-size: var(--text-body-sm);
    color: var(--color-body);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .apps__cover[open] .apps__cover-excerpt {
    display: none;
  }
  .apps__cover-body {
    margin: var(--space-sm) 0 0;
    font-size: var(--text-body-sm);
    line-height: 1.6;
    color: var(--color-body);
    white-space: pre-wrap;
  }

  /* ─── Footer row ─────────────────────────────────────── */
  .apps__foot {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-hairline);
  }
  .apps__link {
    font-size: var(--text-body-sm);
    color: var(--color-link);
    text-decoration: none;
  }
  .apps__link:hover {
    text-decoration: underline;
  }
  .apps__id {
    font-size: var(--text-caption);
    color: var(--color-mute);
    font-family: var(--font-mono);
  }
  .apps__id code {
    background: var(--color-canvas);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--color-ink);
  }

  /* ─── Manage button + action row ────────────────────── */
  .apps__manage {
    margin-left: auto;
    position: relative;
  }
  .apps__manage-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }
  .apps__manage-row[hidden] {
    display: none;
  }
  .apps__action-reject {
    color: var(--color-error);
  }
  .apps__action-reject[data-confirming='true'] {
    background: var(--color-error);
    color: var(--color-on-primary);
  }
</style>

<script>
  import { mountApplicants } from '../../scripts/applicants';
  mountApplicants();
</script>
