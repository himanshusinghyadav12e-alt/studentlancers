---
import AuthLayout from '../layouts/AuthLayout.astro';
import Input from '../components/ui/Input.astro';
import Field from '../components/ui/Field.astro';
import Button from '../components/ui/Button.astro';

/**
 * /signup
 *
 * Creates a StudentLancers account. The account type selector is a
 * styled radio group (Student vs Company) — the selected option gets
 * a filled primary dot and elevated surface via the .is-selected class
 * applied in the client script.
 */
---

<AuthLayout
  title="Create your account · StudentLancers"
  description="Sign up for StudentLancers to hire college talent or land paid freelance gigs."
  eyebrow="Get started · Free to join"
  heading="Create your account"
  subheading="Two minutes to set up. No card required. Switch between sides any time."
>
  <form
    class="auth-form"
    novalidate
    aria-describedby="signup-alert"
    data-auth-form="signup"
  >
    <div class="auth-demo-banner" data-demo-banner hidden></div>
    <div
      id="signup-alert"
      class="auth-alert"
      role="alert"
      data-form-alert
      hidden
    >
      <svg class="auth-alert__icon" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.4" />
        <path d="M9 5.5v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        <circle cx="9" cy="12.4" r="0.9" fill="currentColor" />
      </svg>
      <div class="auth-alert__body">
        <p class="auth-alert__title" data-form-alert-title>Something went wrong.</p>
        <p class="auth-alert__msg" data-form-alert-msg>Please try again.</p>
      </div>
    </div>

    <div
      class="auth-alert auth-alert--info"
      role="status"
      data-account-type-hint
    >
      <svg class="auth-alert__icon" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.4" />
        <path d="M9 8.5v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        <circle cx="9" cy="5.6" r="0.9" fill="currentColor" />
      </svg>
      <div class="auth-alert__body">
        <p class="auth-alert__msg">
          Pick the side that fits you — you can switch any time from account settings.
        </p>
      </div>
    </div>

    <Field label="I am a…" for="signup-account-type">
      <div class="auth-choices" role="radiogroup" aria-label="Account type" id="signup-account-type">
        <label class="auth-choice" data-choice>
          <input
            type="radio"
            class="auth-choice__input"
            name="account_type"
            value="student"
            checked
            data-account-type="student"
          />
          <span class="auth-choice__body">
            <span class="auth-choice__title">
              <span class="auth-choice__dot" aria-hidden="true"></span>
              Student
            </span>
            <span class="auth-choice__desc">Land paid gigs and build a portfolio</span>
          </span>
        </label>

        <label class="auth-choice" data-choice>
          <input
            type="radio"
            class="auth-choice__input"
            name="account_type"
            value="company"
            data-account-type="company"
          />
          <span class="auth-choice__body">
            <span class="auth-choice__title">
              <span class="auth-choice__dot" aria-hidden="true"></span>
              Company
            </span>
            <span class="auth-choice__desc">Hire vetted college talent</span>
          </span>
        </label>
      </div>
    </Field>

    <Field label="Full name" for="signup-name">
      <Input
        type="text"
        id="signup-name"
        name="name"
        size="lg"
        placeholder="Avery Patel"
        autocomplete="name"
        required
        minlength="2"
        data-field="name"
      />
    </Field>

    <Field label="Work email" for="signup-email">
      <Input
        type="email"
        id="signup-email"
        name="email"
        size="lg"
        placeholder="you@university.edu"
        autocomplete="email"
        required
        data-field="email"
      />
    </Field>

    <Field label="Password" for="signup-password" hint="At least 8 characters with a number and a letter.">
      <span class="auth-input-wrap">
        <Input
          type="password"
          id="signup-password"
          name="password"
          size="lg"
          placeholder="Create a strong password"
          autocomplete="new-password"
          required
          minlength="8"
          data-field="password"
          data-password-meter
        />
        <button
          type="button"
          class="auth-input-toggle"
          aria-label="Show password"
          aria-pressed="false"
          data-password-toggle
          data-target="signup-password"
        >
          <svg class="auth-input-toggle__show" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1.5 8s2.5-4.5 6.5-4.5S14.5 8 14.5 8 12 12.5 8 12.5 1.5 8 1.5 8Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4" />
          </svg>
          <svg class="auth-input-toggle__hide" viewBox="0 0 16 16" fill="none" aria-hidden="true" hidden>
            <path d="M2 2l12 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M3.5 8c.7-1 2.2-2.7 4.5-2.7 1.1 0 2.1.4 2.9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M6.5 10.5c.5.3 1 .5 1.5.5 2.3 0 3.8-1.7 4.5-2.7-.3-.4-.7-.9-1.2-1.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
        </button>
      </span>
      <div class="auth-meter" data-strength-meter hidden>
        <div class="auth-meter__bars" aria-hidden="true">
          <span class="auth-meter__bar"></span>
          <span class="auth-meter__bar"></span>
          <span class="auth-meter__bar"></span>
          <span class="auth-meter__bar"></span>
        </div>
        <span class="auth-meter__label" data-strength-label>Strength</span>
      </div>
    </Field>

    <Field label="Confirm password" for="signup-confirm">
      <span class="auth-input-wrap">
        <Input
          type="password"
          id="signup-confirm"
          name="confirm"
          size="lg"
          placeholder="Type your password again"
          autocomplete="new-password"
          required
          minlength="8"
          data-field="confirm"
        />
        <button
          type="button"
          class="auth-input-toggle"
          aria-label="Show password"
          aria-pressed="false"
          data-password-toggle
          data-target="signup-confirm"
        >
          <svg class="auth-input-toggle__show" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1.5 8s2.5-4.5 6.5-4.5S14.5 8 14.5 8 12 12.5 8 12.5 1.5 8 1.5 8Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4" />
          </svg>
          <svg class="auth-input-toggle__hide" viewBox="0 0 16 16" fill="none" aria-hidden="true" hidden>
            <path d="M2 2l12 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M3.5 8c.7-1 2.2-2.7 4.5-2.7 1.1 0 2.1.4 2.9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <path d="M6.5 10.5c.5.3 1 .5 1.5.5 2.3 0 3.8-1.7 4.5-2.7-.3-.4-.7-.9-1.2-1.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
        </button>
      </span>
    </Field>

    <label class="auth-check" data-terms>
      <span class="auth-check__box" aria-hidden="true">
        <svg viewBox="0 0 12 12" fill="none">
          <path d="M2.5 6.5l2.5 2.5L9.5 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <input
        type="checkbox"
        class="auth-check__input"
        name="terms"
        id="signup-terms"
        required
        data-field="terms"
      />
      <span>
        I agree to the
        <a class="auth-link" href="/terms">Terms of Service</a>
        and
        <a class="auth-link" href="/privacy">Privacy Policy</a>.
      </span>
    </label>

    <Button
      variant="primary"
      size="lg"
      type="submit"
      class="auth-submit"
      data-submit
    >
      <span class="auth-submit__spinner" aria-hidden="true"></span>
      <span data-submit-label>Create account</span>
    </Button>

    <p class="auth-switch">
      Already have an account? <a href="/login">Log in</a>
    </p>
  </form>
</AuthLayout>

<script>
  import { mountAuthForms } from '../scripts/auth-form';
  mountAuthForms();
</script>

<style>
  .auth-link {
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-line);
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .auth-link:hover {
    color: var(--color-link-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .auth-link:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }
</style>
