---
import DashboardLayout, { type NavItem } from '../../layouts/DashboardLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import {
  SKILL_CATEGORIES,
  ACHIEVEMENTS,
  MOCK_LEADERBOARD,
  MOCK_REPUTATION,
  SKILL_RANKINGS,
  getLeaderboardByCategory,
  searchSkills,
} from '../../data/leaderboard';
import type { LeaderboardCategory } from '../../lib/types';

const nav: NavItem[] = [
  { href: '/student/dashboard', label: 'Overview', icon: 'home' },
  { href: '/student/find-work', label: 'Find work', icon: 'brief' },
  { href: '/student/applications', label: 'My applications', icon: 'inbox' },
  { href: '/student/earnings', label: 'Earnings', icon: 'wallet' },
  { href: '/student/leaderboard', label: 'Leaderboard', icon: 'leaderboard', current: true },
  { href: '/student/reviews', label: 'Reviews', icon: 'reviews' },
  { href: '/student/profile', label: 'Profile', icon: 'profile' },
  { href: '/student/settings', label: 'Settings', icon: 'settings' },
];

const user = Astro.locals.user;
const studentName = user?.name ?? 'there';

const activeCategory: LeaderboardCategory = 'react';
const entries = getLeaderboardByCategory(activeCategory);
const top3 = entries.slice(0, 3);
const rest = entries.slice(3);

const rep = MOCK_REPUTATION;
const earned = ACHIEVEMENTS.filter((a) => a.earnedAt);
const inProgress = ACHIEVEMENTS.filter((a) => !a.earnedAt);

const skillsJson = JSON.stringify(SKILL_CATEGORIES);
const rankingsJson = JSON.stringify(SKILL_RANKINGS);
const categoriesJson = JSON.stringify(SKILL_CATEGORIES);
---

<DashboardLayout
  title="Leaderboard · StudentLancers"
  description="See how you rank against other students."
  name={studentName}
  role="Student"
  nav={nav}
>
  <header class="dash-page-head">
    <div class="dash-page-head__copy">
      <span class="dash-page-head__eyebrow">Rankings</span>
      <h1 class="dash-page-head__title">Leaderboard</h1>
      <p class="dash-page-head__lead">
        Search any skill to see rankings. Compare yourself with peers and track your progress.
      </p>
    </div>
    <div class="dash-page-head__actions">
      <Badge mono variant="cyan">June 2026</Badge>
    </div>
  </header>

  {/* ─── Skill Search ──────────────────────────────────────── */}
  <div class="lb-search" data-lb-search-wrap>
    <div class="lb-search__input-wrap">
      <svg class="lb-search__icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.4" />
        <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
      </svg>
      <input
        type="text"
        class="lb-search__input"
        placeholder="Search skills (React, Python, Java, UI Design, SEO...)"
        data-lb-search
        autocomplete="off"
        aria-label="Search skills"
      />
      <button class="lb-search__clear" data-lb-clear type="button" aria-label="Clear search" hidden>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3.5 3.5l7 7M10.5 3.5l-7 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
      </button>
    </div>
    <div class="lb-search__dropdown" data-lb-dropdown hidden>
      <div class="lb-search__suggestions" data-lb-suggestions></div>
    </div>
  </div>

  {/* ─── Skill Stats Grid ──────────────────────────────────── */}
  <section class="lb-stats-grid" data-lb-stats-section>
    <div class="lb-stat-card" data-lb-stat="total">
      <span class="lb-stat-card__icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <circle cx="10" cy="6" r="3" stroke="currentColor" stroke-width="1.4" />
          <path d="M4 17c.5-2.5 2.7-4.5 6-4.5s5.5 2 6 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
      </span>
      <span class="lb-stat-card__value" data-lb-stat-value="total">342</span>
      <span class="lb-stat-card__label">Total Students</span>
    </div>
    <div class="lb-stat-card" data-lb-stat="top">
      <span class="lb-stat-card__icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 2l2.4 5 5.6.7-4 3.9.9 5.6L10 14.6l-4.9 2.6.9-5.6-4-3.9 5.6-.7L10 2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="lb-stat-card__value" data-lb-stat-value="top">Priya Sharma</span>
      <span class="lb-stat-card__label">Top Performer</span>
    </div>
    <div class="lb-stat-card" data-lb-stat="rating">
      <span class="lb-stat-card__icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 1.5l2.1 4.3 4.7.6-3.4 3.3.8 4.7L10 12.3l-4.2 2.1.8-4.7L3.2 6.4l4.7-.6L10 1.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="lb-stat-card__value" data-lb-stat-value="rating">4.6</span>
      <span class="lb-stat-card__label">Average Rating</span>
    </div>
    <div class="lb-stat-card" data-lb-stat="reputation">
      <span class="lb-stat-card__icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4" />
          <path d="M10 6v4l2.5 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="lb-stat-card__value" data-lb-stat-value="reputation">98</span>
      <span class="lb-stat-card__label">Highest Reputation</span>
    </div>
    <div class="lb-stat-card" data-lb-stat="projects">
      <span class="lb-stat-card__icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <rect x="3" y="5" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4" />
          <path d="M7 5V3.5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1V5" stroke="currentColor" stroke-width="1.4" />
          <path d="M3 9h14" stroke="currentColor" stroke-width="1.4" />
        </svg>
      </span>
      <span class="lb-stat-card__value" data-lb-stat-value="projects">1,840</span>
      <span class="lb-stat-card__label">Projects Completed</span>
    </div>
  </section>

  {/* ─── Your Rank Card ────────────────────────────────────── */}
  <section class="lb-rank-card" data-lb-rank-card>
    <div class="lb-rank-card__header">
      <h2 class="lb-rank-card__title">Your Rank</h2>
      <Badge mono variant="success" data-lb-rank-skill>React</Badge>
    </div>
    <div class="lb-rank-card__grid">
      <div class="lb-rank-card__stat">
        <span class="lb-rank-card__stat-label">Rank</span>
        <span class="lb-rank-card__stat-value" data-lb-rank-pos>#12</span>
      </div>
      <div class="lb-rank-card__stat">
        <span class="lb-rank-card__stat-label">Skill Score</span>
        <span class="lb-rank-card__stat-value" data-lb-rank-score>82</span>
      </div>
      <div class="lb-rank-card__stat">
        <span class="lb-rank-card__stat-label">Percentile</span>
        <span class="lb-rank-card__stat-value lb-rank-card__stat-value--highlight" data-lb-rank-pct>Top 5%</span>
      </div>
      <div class="lb-rank-card__stat">
        <span class="lb-rank-card__stat-label">Movement</span>
        <span class="lb-rank-card__stat-value" data-lb-rank-move>
          <span class="lb-rank-card__arrow lb-rank-card__arrow--up">↑</span>
          <span data-lb-rank-move-amt>3</span>
        </span>
      </div>
    </div>
  </section>

  {/* ─── Category Tabs ─────────────────────────────────────── */}
  <nav class="lb-tabs" aria-label="Skill categories">
    {SKILL_CATEGORIES.map((cat) => (
      <button
        class:list={['lb-tab', cat.id === activeCategory && 'is-active']}
        data-category={cat.id}
        type="button"
      >
        <span class="lb-tab__icon">{cat.icon}</span>
        {cat.label}
      </button>
    ))}
  </nav>

  {/* ─── Top 3 Podium ──────────────────────────────────────── */}
  {top3.length >= 3 && (
    <section class="lb-podium" aria-label="Top 3">
      <div class="lb-podium__item lb-podium__item--2">
        <div class="lb-podium__avatar" data-color="silver">{top3[1].initials}</div>
        <span class="lb-podium__name">{top3[1].name}</span>
        <span class="lb-podium__college">{top3[1].college}</span>
        <span class="lb-podium__score">{top3[1].score}</span>
        <span class="lb-podium__rank">2nd</span>
      </div>
      <div class="lb-podium__item lb-podium__item--1">
        <div class="lb-podium__crown">👑</div>
        <div class="lb-podium__avatar" data-color="gold">{top3[0].initials}</div>
        <span class="lb-podium__name">{top3[0].name}</span>
        <span class="lb-podium__college">{top3[0].college}</span>
        <span class="lb-podium__score">{top3[0].score}</span>
        <span class="lb-podium__rank">1st</span>
      </div>
      <div class="lb-podium__item lb-podium__item--3">
        <div class="lb-podium__avatar" data-color="bronze">{top3[2].initials}</div>
        <span class="lb-podium__name">{top3[2].name}</span>
        <span class="lb-podium__college">{top3[2].college}</span>
        <span class="lb-podium__score">{top3[2].score}</span>
        <span class="lb-podium__rank">3rd</span>
      </div>
    </section>
  )}

  {/* ─── Rankings Table ─────────────────────────────────────── */}
  <section class="dash-card" aria-label="Rankings">
    <div class="dash-card__head">
      <h2 class="dash-card__title">Full Rankings</h2>
      <Badge mono variant="secondary" data-lb-count>{entries.length} students</Badge>
    </div>
    <div class="dash-card__body lb-table-wrap">
      <table class="lb-table" aria-label="Leaderboard rankings">
        <thead>
          <tr>
            <th class="lb-table__rank">#</th>
            <th class="lb-table__name">Student</th>
            <th class="lb-table__stat">Score</th>
            <th class="lb-table__stat lb-table__stat--hide-mobile">Rating</th>
            <th class="lb-table__stat lb-table__stat--hide-mobile">Projects</th>
            <th class="lb-table__stat">On-time</th>
          </tr>
        </thead>
        <tbody data-lb-table-body>
          {rest.map((e) => (
            <tr>
              <td class="lb-table__rank">{e.rank}</td>
              <td class="lb-table__name">
                <span class="lb-table__avatar" data-color="cyan">{e.initials}</span>
                <span class="lb-table__info">
                  <span class="lb-table__student">{e.name}</span>
                  <span class="lb-table__college">{e.college}</span>
                </span>
              </td>
              <td class="lb-table__stat">{e.score}</td>
              <td class="lb-table__stat lb-table__stat--hide-mobile">{e.clientRating}</td>
              <td class="lb-table__stat lb-table__stat--hide-mobile">{e.projectsCompleted}</td>
              <td class="lb-table__stat">{e.onTimeDelivery}%</td>
            </tr>
          ))}
          {rest.length === 0 && (
            <tr>
              <td colspan="6" class="lb-table__empty">
                <div class="lb-empty-state">
                  <span class="lb-empty-state__icon">📊</span>
                  <span class="lb-empty-state__text">No rankings found for this skill yet.</span>
                </div>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  {/* ─── Reputation Score ────────────────────────────────────── */}
  <section class="dash-card" aria-label="Your reputation score">
    <div class="dash-card__head">
      <h2 class="dash-card__title">Your Reputation</h2>
      <Badge mono variant="cyan">Updated {rep.updatedAt}</Badge>
    </div>
    <div class="dash-card__body">
      <div class="lb-rep">
        <div class="lb-rep__score-ring">
          <span class="lb-rep__overall">{rep.overall}</span>
          <span class="lb-rep__label">Overall</span>
        </div>
        <div class="lb-rep__breakdown">
          <div class="lb-rep__bar">
            <span class="lb-rep__bar-label">Client Rating</span>
            <div class="lb-rep__bar-track">
              <div class="lb-rep__bar-fill" style={`width: ${(rep.clientRating / 5) * 100}%`}></div>
            </div>
            <span class="lb-rep__bar-value">{rep.clientRating}/5</span>
          </div>
          <div class="lb-rep__bar">
            <span class="lb-rep__bar-label">Project Completion</span>
            <div class="lb-rep__bar-track">
              <div class="lb-rep__bar-fill" style={`width: ${rep.projectCompletion}%`}></div>
            </div>
            <span class="lb-rep__bar-value">{rep.projectCompletion}%</span>
          </div>
          <div class="lb-rep__bar">
            <span class="lb-rep__bar-label">On-Time Delivery</span>
            <div class="lb-rep__bar-track">
              <div class="lb-rep__bar-fill" style={`width: ${rep.onTimeDelivery}%`}></div>
            </div>
            <span class="lb-rep__bar-value">{rep.onTimeDelivery}%</span>
          </div>
          <div class="lb-rep__bar">
            <span class="lb-rep__bar-label">Repeat Clients</span>
            <div class="lb-rep__bar-track">
              <div class="lb-rep__bar-fill" style={`width: ${rep.repeatClientRate}%`}></div>
            </div>
            <span class="lb-rep__bar-value">{rep.repeatClientRate}%</span>
          </div>
          <div class="lb-rep__bar">
            <span class="lb-rep__bar-label">Quality Score</span>
            <div class="lb-rep__bar-track">
              <div class="lb-rep__bar-fill" style={`width: ${rep.qualityScore}%`}></div>
            </div>
            <span class="lb-rep__bar-value">{rep.qualityScore}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ─── Achievement Badges ──────────────────────────────────── */}
  <section class="dash-card" aria-label="Achievement badges">
    <div class="dash-card__head">
      <h2 class="dash-card__title">Achievements</h2>
      <Badge mono variant="success">{earned.length}/{ACHIEVEMENTS.length} earned</Badge>
    </div>
    <div class="dash-card__body">
      <div class="lb-badges">
        {ACHIEVEMENTS.map((a) => (
          <div class:list={['lb-badge', a.earnedAt ? 'lb-badge--earned' : 'lb-badge--locked']}>
            <span class="lb-badge__icon" aria-hidden="true">{a.icon}</span>
            <span class="lb-badge__name">{a.name}</span>
            <span class="lb-badge__desc">{a.description}</span>
            {!a.earnedAt && (
              <div class="lb-badge__progress">
                <div class="lb-badge__progress-track">
                  <div class="lb-badge__progress-fill" style={`width: ${a.progress}%`}></div>
                </div>
                <span class="lb-badge__progress-text">{a.progress}%</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <script define:vars={{ skillsJson, rankingsJson, categoriesJson }}>
    const SKILL_DATA = JSON.parse(skillsJson);
    const RANKING_DATA = JSON.parse(rankingsJson);
    const CAT_DATA = JSON.parse(categoriesJson);

    const searchInput = document.querySelector('[data-lb-search]');
    const clearBtn = document.querySelector('[data-lb-clear]');
    const dropdown = document.querySelector('[data-lb-dropdown]');
    const suggestionsEl = document.querySelector('[data-lb-suggestions]');
    const searchWrap = document.querySelector('[data-lb-search-wrap]');

    if (searchInput && clearBtn && dropdown && suggestionsEl && searchWrap) {
      let activeIdx = -1;
      let filtered = [];

      function getFiltered(q) {
        const query = q.toLowerCase().trim();
        if (!query) return SKILL_DATA;
        return SKILL_DATA.filter(s => s.label.toLowerCase().includes(query));
      }

      function renderSuggestions(items) {
        filtered = items;
        activeIdx = -1;
        if (items.length === 0) {
          suggestionsEl.innerHTML = '<div class="lb-search__no-results">No skills found</div>';
          dropdown.hidden = false;
          return;
        }
        suggestionsEl.innerHTML = items.map((item, i) => `
          <button class="lb-search__item" data-skill-id="${item.id}" data-idx="${i}" type="button">
            <span class="lb-search__item-icon">${item.icon}</span>
            <span class="lb-search__item-label">${item.label}</span>
          </button>
        `).join('');
        dropdown.hidden = false;
      }

      function selectSkill(skillId) {
        const cat = CAT_DATA.find(c => c.id === skillId);
        if (cat) {
          searchInput.value = cat.label;
          dropdown.hidden = true;
          clearBtn.hidden = false;
          updateLeaderboard(skillId);
        }
      }

      function updateLeaderboard(category) {
        const ranking = RANKING_DATA.find(r => r.category === category);
        const tabBtns = document.querySelectorAll('[data-category]');
        tabBtns.forEach(btn => {
          btn.classList.toggle('is-active', btn.dataset.category === category);
        });

        // Update stats
        if (ranking) {
          const totalEl = document.querySelector('[data-lb-stat-value="total"]');
          const topEl = document.querySelector('[data-lb-stat-value="top"]');
          const ratingEl = document.querySelector('[data-lb-stat-value="rating"]');
          const repEl = document.querySelector('[data-lb-stat-value="reputation"]');
          const projEl = document.querySelector('[data-lb-stat-value="projects"]');
          if (totalEl) totalEl.textContent = ranking.totalStudents.toLocaleString();
          if (topEl) topEl.textContent = ranking.topPerformer;
          if (ratingEl) ratingEl.textContent = ranking.averageRating.toFixed(1);
          if (repEl) repEl.textContent = ranking.highestReputation;
          if (projEl) projEl.textContent = ranking.totalProjects.toLocaleString();

          // Update rank card
          const rankSkillEl = document.querySelector('[data-lb-rank-skill]');
          const rankPosEl = document.querySelector('[data-lb-rank-pos]');
          const rankScoreEl = document.querySelector('[data-lb-rank-score]');
          const rankPctEl = document.querySelector('[data-lb-rank-pct]');
          const rankMoveEl = document.querySelector('[data-lb-rank-move-amt]');
          const rankArrowEl = document.querySelector('[data-lb-rank-move]');

          if (rankSkillEl) rankSkillEl.textContent = ranking.skill;
          if (rankPosEl) rankPosEl.textContent = '#' + ranking.userRank;
          if (rankScoreEl) rankScoreEl.textContent = ranking.userScore;
          if (rankPctEl) rankPctEl.textContent = ranking.userPercentile;
          if (rankMoveEl) rankMoveEl.textContent = ranking.movementAmount || '—';
          if (rankArrowEl) {
            const arrow = rankArrowEl.querySelector('.lb-rank-card__arrow');
            if (arrow) {
              arrow.className = 'lb-rank-card__arrow';
              if (ranking.rankMovement === 'up') {
                arrow.classList.add('lb-rank-card__arrow--up');
                arrow.textContent = '↑';
              } else if (ranking.rankMovement === 'down') {
                arrow.classList.add('lb-rank-card__arrow--down');
                arrow.textContent = '↓';
              } else {
                arrow.classList.add('lb-rank-card__arrow--same');
                arrow.textContent = '—';
              }
            }
          }
        }
      }

      searchInput.addEventListener('input', () => {
        const val = searchInput.value;
        clearBtn.hidden = !val;
        filtered = getFiltered(val);
        renderSuggestions(filtered);
      });

      searchInput.addEventListener('focus', () => {
        filtered = getFiltered(searchInput.value);
        renderSuggestions(filtered);
      });

      searchInput.addEventListener('keydown', (e) => {
        const items = suggestionsEl.querySelectorAll('.lb-search__item');
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIdx = Math.min(activeIdx + 1, items.length - 1);
          items.forEach((el, i) => el.classList.toggle('is-active', i === activeIdx));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIdx = Math.max(activeIdx - 1, 0);
          items.forEach((el, i) => el.classList.toggle('is-active', i === activeIdx));
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIdx >= 0 && items[activeIdx]) {
            selectSkill(items[activeIdx].dataset.skillId);
          } else if (filtered.length > 0) {
            selectSkill(filtered[0].id);
          }
        } else if (e.key === 'Escape') {
          dropdown.hidden = true;
        }
      });

      suggestionsEl.addEventListener('click', (e) => {
        const btn = e.target.closest('.lb-search__item');
        if (btn) selectSkill(btn.dataset.skillId);
      });

      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        clearBtn.hidden = true;
        dropdown.hidden = true;
        searchInput.focus();
        updateLeaderboard('react');
      });

      document.addEventListener('click', (e) => {
        if (!searchWrap.contains(e.target)) {
          dropdown.hidden = true;
        }
      });

      // Tab clicks
      document.querySelectorAll('[data-category]').forEach(tab => {
        tab.addEventListener('click', () => {
          const catId = tab.dataset.category;
          const cat = CAT_DATA.find(c => c.id === catId);
          if (cat) {
            searchInput.value = cat.label;
            clearBtn.hidden = false;
          }
          updateLeaderboard(catId);
        });
      });
    }
  </script>
</DashboardLayout>

<style>
  /* ─── Search Bar ──────────────────────────────────────── */
  .lb-search {
    position: relative;
    margin-bottom: var(--space-md);
  }
  .lb-search__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .lb-search__icon {
    position: absolute;
    left: 14px;
    color: var(--color-mute);
    pointer-events: none;
    z-index: 1;
  }
  .lb-search__input {
    width: 100%;
    padding: 12px 44px 12px 42px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    background: var(--color-canvas);
    color: var(--color-ink);
    font-size: var(--text-body-md);
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }
  .lb-search__input::placeholder {
    color: var(--color-mute);
  }
  .lb-search__input:focus {
    border-color: var(--color-link);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-link) 12%, transparent);
  }
  .lb-search__clear {
    position: absolute;
    right: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    border: none;
    background: var(--color-canvas-soft);
    color: var(--color-mute);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .lb-search__clear:hover {
    background: var(--color-hairline);
