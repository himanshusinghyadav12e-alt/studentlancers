---
import DashboardLayout, { type NavItem } from '../../layouts/DashboardLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import SubPageShell from '../../components/SubPageShell.astro';
import { listApplicationsForApplicant } from '../../lib/api';
import type { ApplicationStatus } from '../../lib/types';

/**
 * /student/applications
 *
 * Lists every application the signed-in student has submitted. Pulls
 * from public.applications via the API helper so the dashboard
 * reflects what the user has actually done. If nothing has been
 * submitted, falls back to the shared empty state via SubPageShell.
 */

const studentNav: NavItem[] = [
  { href: '/student/dashboard', label: 'Overview', icon: 'home' },
  { href: '/student/find-work', label: 'Find work', icon: 'brief' },
  { href: '/student/applications', label: 'My applications', icon: 'inbox', current: true },
  { href: '/student/earnings', label: 'Earnings', icon: 'wallet' },
  { href: '/student/leaderboard', label: 'Leaderboard', icon: 'leaderboard' },
  { href: '/student/reviews', label: 'Reviews', icon: 'reviews' },
  { href: '/student/profile', label: 'Profile', icon: 'profile' },
  { href: '/student/settings', label: 'Settings', icon: 'settings' },
];

const session = Astro.locals.session;
const user = Astro.locals.user;
const studentName = user?.name ?? 'Your name';

let applications: Awaited<ReturnType<typeof listApplicationsForApplicant>> = [];
let loadError: string | null = null;
if (user && user.role === 'student') {
  try {
    applications = await listApplicationsForApplicant(Astro);
  } catch (err) {
    loadError = err instanceof Error ? err.message : 'Could not load applications.';
  }
}

const statusLabel: Record<ApplicationStatus, string> = {
  new: 'In review',
  shortlisted: 'Shortlisted',
  hired: 'Hired',
  rejected: 'Rejected',
};

const statusPill: Record<ApplicationStatus, string> = {
  new: 'dash-pill dash-pill--cyan',
  shortlisted: 'dash-pill dash-pill--violet',
  hired: 'dash-pill dash-pill--success',
  rejected: 'dash-pill dash-pill--warning',
};
---

{
  applications.length === 0 ? (
    <SubPageShell
      title="My applications · StudentLancers"
      description="Track every brief you have applied to on StudentLancers."
      name={studentName}
      role="Student"
      nav={studentNav}
      eyebrow="Applications"
      heading={loadError ? 'We could not load your applications' : 'Your applications'}
      body={
        loadError
          ? loadError
          : 'When you apply to a brief, it shows up here with its current status — in review, invited to interview, or hired. Until you submit your first one, the list is empty.'
      }
      ctaLabel="Find a brief to apply to"
      ctaHref="/student/find-work"
      badge={loadError ? 'Error' : 'Empty'}
    />
  ) : (
    <DashboardLayout
      title="My applications · StudentLancers"
      description="Every brief you have applied to on StudentLancers."
      name={studentName}
      role="Student"
      nav={studentNav}
    >
      <header class="dash-page-head">
        <div class="dash-page-head__copy">
          <span class="dash-page-head__eyebrow">Applications</span>
          <h1 class="dash-page-head__title">Your applications</h1>
          <p class="dash-page-head__lead">
            {applications.length} {applications.length === 1 ? 'application' : 'applications'} sent. Most companies respond within two business days.
          </p>
        </div>
        <div class="dash-page-head__actions">
          <Button variant="primary" size="md" href="/student/find-work">Find more briefs</Button>
        </div>
      </header>

      <section class="apps" aria-label="Submitted applications">
        <ul class="apps__list" role="list">
          {applications.map((a) => (
            <li class="apps__item">
              <div class="apps__head">
                <div class="apps__chips">
                  <span class={statusPill[a.status]} data-applicant-status-pill>
                    {statusLabel[a.status]}
                  </span>
                </div>
                <span class="apps__date">
                  {new Date(a.created_at).toLocaleDateString(undefined, { month: 'short', day: 'numeric' })}
                </span>
              </div>
              <h2 class="apps__title">
                <a href={`/jobs/${a.job_id}`}>{a.job.title}</a>
              </h2>
              <p class="apps__excerpt">{a.cover.slice(0, 180)}{a.cover.length > 180 ? '…' : ''}</p>
              <div class="apps__meta">
                {a.rate_cents != null && (
                  <span>Proposed rate: <strong>${(a.rate_cents / 100).toFixed(0)}</strong></span>
                )}
                {a.timeline && <span>Timeline: <strong>{a.timeline}</strong></span>}
                <span>Application <code>{a.id.slice(0, 8)}</code></span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    </DashboardLayout>
  )
}

<style>
  .apps {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .apps__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .apps__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-level-1);
  }
  .apps__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }
  .apps__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .apps__date {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-mute);
  }
  .apps__title {
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    font-weight: var(--text-body-md-strong-weight);
    color: var(--color-ink);
    margin: 0;
  }
  .apps__title a {
    color: inherit;
    text-decoration: none;
  }
  .apps__title a:hover {
    color: var(--color-link);
  }
  .apps__excerpt {
    margin: 0;
    font-size: var(--text-body-sm);
    color: var(--color-body);
  }
  .apps__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: var(--text-caption);
    color: var(--color-mute);
    font-family: var(--font-mono);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-hairline);
  }
  .apps__meta code {
    background: var(--color-canvas-soft);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--color-ink);
  }
</style>
