---
import DashboardLayout, { type NavItem } from '../../layouts/DashboardLayout.astro';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import ProfileCompletionCard from '../../components/ProfileCompletionCard.astro';
import { listApplicationsForApplicant } from '../../lib/api';
import type { ApplicationWithJob } from '../../lib/types';

/**
 * /student/dashboard
 *
 * The student side of the marketplace. Reads the signed-in session
 * from the Supabase-backed middleware locals and surfaces real
 * activity (or an explicit empty state) for every list and stat. No
 * fabricated numbers.
 */

const studentNav: NavItem[] = [
  { href: '/student/dashboard', label: 'Overview', icon: 'home', current: true },
  { href: '/student/find-work', label: 'Find work', icon: 'brief' },
  { href: '/student/applications', label: 'My applications', icon: 'inbox' },
  { href: '/student/earnings', label: 'Earnings', icon: 'wallet' },
  { href: '/student/reviews', label: 'Reviews', icon: 'reviews' },
  { href: '/student/profile', label: 'Profile', icon: 'profile' },
  { href: '/student/settings', label: 'Settings', icon: 'settings' },
];

const user = Astro.locals.user;
const profile = Astro.locals.studentProfile;
const studentName = user?.name ?? 'there';
const greeting = user ? `Welcome back, ${studentName.split(' ')[0]}` : 'Welcome';

let myApps: ApplicationWithJob[] = [];
if (user && user.role === 'student') {
  try {
    myApps = await listApplicationsForApplicant(Astro);
  } catch {
    myApps = [];
  }
}
const appsCount = myApps.length;
const recent = myApps.slice(0, 3);
---

<DashboardLayout
  title="Dashboard · StudentLancers"
  description="Your StudentLancers student dashboard."
  name={studentName}
  role="Student"
  nav={studentNav}
>
  <header class="dash-page-head">
    <div class="dash-page-head__copy">
      <span class="dash-page-head__eyebrow">{greeting}</span>
      <h1 class="dash-page-head__title">Find briefs that match your skills.</h1>
      <p class="dash-page-head__lead">
        Pick up where you left off — or browse open briefs by major, skill, and
        weekly hours. You can apply with a single click once your profile is set.
      </p>
    </div>
    <div class="dash-page-head__actions">
      <Button variant="primary" size="md" href="/student/find-work">Browse briefs</Button>
      <Button variant="secondary" size="md" href="/student/profile">Edit profile</Button>
    </div>
  </header>

  <section aria-label="At a glance">
    <div class="dash-stats">
      <div class="dash-stat">
        <span class="dash-stat__label">Active applications</span>
        <span class={`dash-stat__value ${appsCount === 0 ? 'dash-stat__value--placeholder' : ''}`}>
          {appsCount === 0 ? '—' : appsCount}
        </span>
        <span class="dash-stat__hint">{appsCount === 0 ? 'Apply to start tracking' : 'In review or interview'}</span>
      </div>
      <div class="dash-stat">
        <span class="dash-stat__label">Open invites</span>
        <span class="dash-stat__value dash-stat__value--placeholder">—</span>
        <span class="dash-stat__hint">Companies can reach out directly</span>
      </div>
      <div class="dash-stat">
        <span class="dash-stat__label">Earnings (30d)</span>
        <span class="dash-stat__value dash-stat__value--placeholder">$0.00</span>
        <span class="dash-stat__hint">Available after first payout</span>
      </div>
    </div>
  </section>

  {user && user.role === 'student' && (
    <ProfileCompletionCard user={user} profile={profile} />
  )}

  <section class="dash-row" aria-label="Applications and recommendations">
    <div class="dash-card">
      <div class="dash-card__head">
        <h2 class="dash-card__title">Recent applications</h2>
        <Badge mono variant="secondary">{appsCount === 0 ? 'Empty' : `${appsCount} total`}</Badge>
      </div>
      <div class="dash-card__body">
        {recent.length === 0 ? (
          <div class="dash-empty">
            <span class="dash-empty__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M3 9l2-4h14l2 4v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M3 9h4l1 2h8l1-2h4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
              </svg>
            </span>
            <h3 class="dash-empty__title">No applications yet</h3>
            <p class="dash-empty__body">
              When you apply to a brief it will show up here with its current status —
              in review, invited to interview, or hired.
            </p>
            <Button variant="secondary" size="md" href="/student/find-work">Find your first brief</Button>
          </div>
        ) : (
          <ul class="dash-list" role="list">
            {recent.map((a) => (
              <li class="dash-list__item">
                <span class="dash-list-avatar" data-color="cyan" aria-hidden="true">A</span>
                <div class="dash-list__main">
                  <span class="dash-list__title">{a.job.title}</span>
                  <span class="dash-list__sub">
                    {a.rate_cents != null ? `Proposed $${Math.round(a.rate_cents / 100)}` : 'Proposed rate'}
                    {a.timeline ? ` · ${a.timeline}` : ''}
                  </span>
                </div>
                <Badge variant="cyan">{a.status === 'hired' ? 'Hired' : a.status === 'shortlisted' ? 'Shortlisted' : a.status === 'rejected' ? 'Rejected' : 'In review'}</Badge>
              </li>
            ))}
            {appsCount > recent.length && (
              <li class="dash-list__more">
                <a href="/student/applications">See all {appsCount} applications →</a>
              </li>
            )}
          </ul>
        )}
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card__head">
        <h2 class="dash-card__title">Up next</h2>
        <Badge mono variant="cyan">Profile</Badge>
      </div>
      <div class="dash-card__body">
        <p style="margin: 0; color: var(--color-body); font-size: var(--text-body-sm);">
          A complete profile ranks higher in matching. Add at least:
        </p>
        <ul class="dash-list" role="list">
          <li class="dash-list__item">
            <span class="dash-list-avatar" data-color="link" aria-hidden="true">+</span>
            <div class="dash-list__main">
              <span class="dash-list__title">Portfolio link</span>
              <span class="dash-list__sub">GitHub, Behance, or a personal site</span>
            </div>
            <span class="dash-pill dash-pill--warning">Add</span>
          </li>
          <li class="dash-list__item">
            <span class="dash-list-avatar" data-color="violet" aria-hidden="true">+</span>
            <div class="dash-list__main">
              <span class="dash-list__title">Skills (pick 3+)</span>
              <span class="dash-list__sub">Tags power the matching engine</span>
            </div>
            <span class="dash-pill dash-pill--warning">Add</span>
          </li>
          <li class="dash-list__item">
            <span class="dash-list-avatar" data-color="cyan" aria-hidden="true">✓</span>
            <div class="dash-list__main">
              <span class="dash-list__title">Verify your .edu</span>
              <span class="dash-list__sub">Confirmed via the link we sent to your email</span>
            </div>
            <span class="dash-pill dash-pill--success">Done</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="dash-card dash-card--inverted" aria-label="How payments work">
    <div class="dash-card__head">
      <h2 class="dash-card__title">How payouts work</h2>
      <Badge mono variant="success" dot>Paid out</Badge>
    </div>
    <div class="dash-card__body dash-payout-grid">
      <div>
        <span class="dash-pill dash-pill--cyan" style="background: var(--inverted-surface-soft); color: var(--inverted-fg); border-color: var(--inverted-border);">01 · Matched</span>
        <p style="margin: 8px 0 0; color: var(--inverted-fg-muted); font-size: var(--text-body-sm);">
          The company accepts your proposal. You and the company agree on payment method and terms — direct transfer, Stripe, or anything else that works for both sides.
        </p>
      </div>
      <div>
        <span class="dash-pill dash-pill--warning" style="background: var(--inverted-surface-soft); color: var(--inverted-fg); border-color: var(--inverted-border);">02 · Shipped</span>
        <p style="margin: 8px 0 0; color: var(--inverted-fg-muted); font-size: var(--text-body-sm);">
          You submit the work. The company reviews it. If they have changes, the milestone stays open.
        </p>
      </div>
      <div>
        <span class="dash-pill dash-pill--success" style="background: var(--inverted-surface-soft); color: var(--inverted-fg); border-color: var(--inverted-border);">03 · Paid</span>
        <p style="margin: 8px 0 0; color: var(--inverted-fg-muted); font-size: var(--text-body-sm);">
          On approval, the company pays you through whatever method you agreed on — most students use Stripe Connect in supported regions.
        </p>
      </div>
    </div>
  </section>
</DashboardLayout>

<style>
  .dash-list__more {
    list-style: none;
    padding: 8px 0 0;
    text-align: center;
    border-top: 1px solid var(--color-hairline);
  }
  .dash-list__more a {
    font-size: var(--text-body-sm);
    color: var(--color-link);
  }
</style>
