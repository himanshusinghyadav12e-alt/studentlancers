---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Input from '../../components/ui/Input.astro';
import Field from '../../components/ui/Field.astro';
import ThemeToggle from '../../components/ui/ThemeToggle.astro';

/**
 * /jobs/post
 *
 * Multi-section form for posting a brief. Sections:
 *   1. Basics — title, category, summary
 *   2. Scope — budget type, amount, duration, hours/week
 *   3. Skills — tag input (add/remove)
 *   4. Details — full description (textarea)
 *   5. Review — read-only summary + publish
 *
 * On submit, the form:
 *   - validates every required field client-side
 *   - persists the draft to localStorage on every change (autosave)
 *   - clears the draft on successful publish
 *   - shows a success state with a generated brief id
 *
 * No real network calls. The submit handler simulates a 700ms request
 * and returns a fake brief id; replace with the real API later.
 */
---

<Layout title="Post a brief · StudentLancers" description="Post a paid brief and start receiving ranked student proposals." pageAuth="company">
  <a class="skip-link" href="#post-main">Skip to content</a>

  <header class="post-top" data-post-top>
    <div class="ds-container post-top__inner">
      <a href="/" class="nav__brand" aria-label="StudentLancers home">
        <span class="nav__logo" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <rect x="0.5" y="0.5" width="21" height="21" rx="5.5" fill="var(--color-primary)" />
            <path d="M6 7.5L11 4.5L16 7.5V14.5L11 17.5L6 14.5V7.5Z" stroke="white" stroke-width="1.4" stroke-linejoin="round" />
            <path d="M11 4.5V11M11 11L16 7.5M11 11L6 7.5M11 11V17.5" stroke="white" stroke-width="1.4" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="nav__brand-text">StudentLancers</span>
      </a>
      <nav class="post-top__nav" aria-label="Quick links">
        <a class="post-top__link" href="/company/dashboard">Dashboard</a>
        <a class="post-top__link" href="/company/applicants">Applicants</a>
      </nav>
      <div class="post-top__right">
        <ThemeToggle size="md" />
        <Button variant="secondary-sm" size="md" href="/company/dashboard">Save & exit</Button>
      </div>
    </div>
  </header>

  <main id="post-main" class="post-page">
    <div class="ds-container post-page__inner">
      <header class="post-page__head">
        <span class="post-page__eyebrow">New brief</span>
        <h1 class="post-page__title">Post a brief</h1>
        <p class="post-page__lead">
          StudentLancers helps skilled students showcase their talent, gain
          real-world experience, and connect with companies looking for
          ambitious talent.
        </p>
        <ul class="post-page__fields" aria-label="Supported fields">
          <li>Web Development</li>
          <li>Full Stack Development</li>
          <li>Mobile Development</li>
          <li>UI/UX Design</li>
          <li>Graphic Design</li>
          <li>Video Editing</li>
          <li>Content Writing</li>
          <li>Marketing</li>
          <li>Automation</li>
          <li>AI</li>
          <li>And more.</li>
        </ul>
      </header>

      <div class="post-grid">
        <form
          class="post-form"
          novalidate
          aria-describedby="post-alert"
          data-post-form
        >
          <div
            id="post-alert"
            class="post-alert"
            role="status"
            aria-live="polite"
            data-form-alert
            hidden
          >
            <svg class="post-alert__icon" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.4" />
              <path d="M9 5.5v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
              <circle cx="9" cy="12.4" r="0.9" fill="currentColor" />
            </svg>
            <div class="post-alert__body">
              <p class="post-alert__title" data-form-alert-title>A few fields need attention.</p>
              <p class="post-alert__msg" data-form-alert-msg>Check the highlighted fields below and try again.</p>
            </div>
            <button type="button" class="post-alert__close" data-form-alert-close aria-label="Dismiss">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M3 3l6 6M9 3l-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
              </svg>
            </button>
          </div>

          {/* ── 1. Basics ──────────────────────────────────── */}
          <section class="post-section" aria-labelledby="post-basics">
            <header class="post-section__head">
              <span class="post-section__num">01</span>
              <div>
                <h2 id="post-basics" class="post-section__title">Basics</h2>
                <p class="post-section__sub">Help students understand the work at a glance.</p>
              </div>
            </header>

            <Field label="Brief title" for="post-title" hint="A short, specific name. 4–80 characters.">
              <Input
                type="text"
                id="post-title"
                name="title"
                size="lg"
                placeholder="e.g. Brand designer for a 4-page Webflow site"
                maxlength="80"
                minlength="4"
                required
                data-field="title"
              />
            </Field>

            <Field label="Category" for="post-category">
              <span class="auth-input-wrap">
                <select
                  id="post-category"
                  name="category"
                  class="ds-input ds-input--input ds-input--size-lg ds-input--default ds-input--select"
                  required
                  data-field="category"
                >
                  <option value="" disabled selected>Pick a category</option>
                  <option value="web-development">Web Development</option>
                  <option value="mobile-development">Mobile Development</option>
                  <option value="uiux-design">UI/UX Design</option>
                  <option value="graphic-design">Graphic Design</option>
                  <option value="video-editing">Video Editing</option>
                  <option value="content-writing">Content Writing</option>
                  <option value="copywriting">Copywriting</option>
                  <option value="seo">SEO</option>
                  <option value="digital-marketing">Digital Marketing</option>
                  <option value="social-media-management">Social Media Management</option>
                  <option value="data-entry">Data Entry</option>
                  <option value="virtual-assistant">Virtual Assistant</option>
                  <option value="ai-machine-learning">AI / Machine Learning</option>
                  <option value="automation">Automation</option>
                  <option value="cybersecurity">Cybersecurity</option>
                  <option value="devops">DevOps</option>
                  <option value="game-development">Game Development</option>
                  <option value="wordpress">WordPress</option>
                  <option value="shopify">Shopify</option>
                  <option value="ecommerce">E-commerce</option>
                  <option value="customer-support">Customer Support</option>
                  <option value="sales">Sales</option>
                  <option value="business-research">Business Research</option>
                  <option value="finance">Finance</option>
                  <option value="accounting">Accounting</option>
                  <option value="tutoring">Tutoring</option>
                  <option value="other">Other</option>
                </select>
                <svg class="ds-input__select-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </Field>

            <Field label="Summary" for="post-summary" hint="One or two sentences. This appears in the listing.">
              <textarea
                id="post-summary"
                name="summary"
                class="ds-input ds-input--textarea ds-input--size-lg ds-input--default"
                rows="3"
                placeholder="A brand designer to translate our existing Figma into a polished Webflow site. Two-week engagement."
                maxlength="280"
                required
                data-field="summary"
              ></textarea>
            </Field>
          </section>

          {/* ── 2. Scope ───────────────────────────────────── */}
          <section class="post-section" aria-labelledby="post-scope">
            <header class="post-section__head">
              <span class="post-section__num">02</span>
              <div>
                <h2 id="post-scope" class="post-section__title">Scope</h2>
                <p class="post-section__sub">How long, how much, and how many hours per week.</p>
              </div>
            </header>

            <fieldset class="post-radio-group" data-budget-type>
              <legend class="post-radio-group__legend">Budget type</legend>
              <div class="post-radio-group__row">
                <label class="auth-choice" data-choice>
                  <input type="radio" class="auth-choice__input" name="budget_type" value="fixed" checked data-field="budget_type" />
                  <span class="auth-choice__body">
                    <span class="auth-choice__title">
                      <span class="auth-choice__dot" aria-hidden="true"></span>
                      Fixed price
                    </span>
                    <span class="auth-choice__desc">One payment on approval</span>
                  </span>
                </label>
                <label class="auth-choice" data-choice>
                  <input type="radio" class="auth-choice__input" name="budget_type" value="hourly" data-field="budget_type" />
                  <span class="auth-choice__body">
                    <span class="auth-choice__title">
                      <span class="auth-choice__dot" aria-hidden="true"></span>
                      Hourly
                    </span>
                    <span class="auth-choice__desc">Pay for hours tracked in-app</span>
                  </span>
                </label>
              </div>
            </fieldset>

            <div class="post-grid-2">
              <Field label="Amount (USD)" for="post-budget">
                <Input
                  type="number"
                  id="post-budget"
                  name="budget"
                  size="lg"
                  placeholder="e.g. 1200"
                  min="20"
                  step="1"
                  required
                  data-field="budget"
                />
              </Field>
              <Field label="Duration" for="post-duration">
                <span class="auth-input-wrap">
                  <select
                    id="post-duration"
                    name="duration"
                    class="ds-input ds-input--input ds-input--size-lg ds-input--default ds-input--select"
                    required
                    data-field="duration"
                  >
                    <option value="" disabled selected>Pick a length</option>
                    <option value="1week">Less than 1 week</option>
                    <option value="2weeks">1–2 weeks</option>
                    <option value="1month">2–4 weeks</option>
                    <option value="3months">1–3 months</option>
                    <option value="ongoing">Ongoing</option>
                  </select>
                  <svg class="ds-input__select-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </Field>
            </div>

            <Field label="Hours per week" for="post-hours">
              <span class="auth-input-wrap">
                <select
                  id="post-hours"
                  name="hours"
                  class="ds-input ds-input--input ds-input--size-lg ds-input--default ds-input--select"
                  required
                  data-field="hours"
                >
                  <option value="" disabled selected>Pick a load</option>
                  <option value="1-5">1–5 hrs / week</option>
                  <option value="5-10">5–10 hrs / week</option>
                  <option value="10-20">10–20 hrs / week</option>
                  <option value="20+">20+ hrs / week</option>
                </select>
                <svg class="ds-input__select-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </Field>
          </section>

          {/* ── 3. Skills ──────────────────────────────────── */}
          <section class="post-section" aria-labelledby="post-skills">
            <header class="post-section__head">
              <span class="post-section__num">03</span>
              <div>
                <h2 id="post-skills" class="post-section__title">Skills</h2>
                <p class="post-section__sub">Add 3–8 tags. Press Enter to add. Click a tag to remove.</p>
              </div>
            </header>

            <div class="post-tags" data-tags data-field="skills">
              <ul class="post-tags__list" data-tags-list role="list" aria-label="Selected skills"></ul>
              <input
                type="text"
                id="post-skill-input"
                class="post-tags__input"
                placeholder="e.g. Figma, Webflow, CSS"
                aria-label="Add a skill"
                maxlength="32"
                data-tags-input
              />
            </div>
          </section>

          {/* ── 4. Details ─────────────────────────────────── */}
          <section class="post-section" aria-labelledby="post-details">
            <header class="post-section__head">
              <span class="post-section__num">04</span>
              <div>
                <h2 id="post-details" class="post-section__title">Details</h2>
                <p class="post-section__sub">The full brief. What is in scope, what is not, and any references.</p>
              </div>
            </header>

            <Field label="Description" for="post-description" hint="Markdown is fine. Aim for 200+ characters.">
              <textarea
                id="post-description"
                name="description"
                class="ds-input ds-input--textarea ds-input--size-lg ds-input--default"
                rows="8"
                placeholder="## What we're building&#10;&#10;…"
                minlength="200"
                required
                data-field="description"
              ></textarea>
            </Field>

            <Field label="Portfolio or reference links" for="post-links" hint="Optional. Paste one link per line.">
              <textarea
                id="post-links"
                name="links"
                class="ds-input ds-input--textarea ds-input--size-lg ds-input--default"
                rows="3"
                placeholder="https://figma.com/…&#10;https://example.com/…"
                data-field="links"
              ></textarea>
            </Field>
          </section>

          {/* ── Footer actions ─────────────────────────────── */}
          <footer class="post-form__foot">
            <p class="post-form__draft" data-draft-status>Draft auto-saves as you type.</p>
            <div class="post-form__actions">
              <Button variant="ghost" size="md" type="button" data-clear-draft>Clear draft</Button>
              <Button variant="primary" size="md" type="submit" data-submit>
                <span class="auth-submit__spinner" aria-hidden="true"></span>
                <span data-submit-label>Publish brief</span>
              </Button>
            </div>
          </footer>
        </form>

        <aside class="post-summary" aria-label="Brief summary">
          <div class="dash-card" data-summary>
            <div class="dash-card__head">
              <h2 class="dash-card__title">Live preview</h2>
              <span class="dash-pill" data-summary-status>Empty</span>
            </div>
            <div class="dash-card__body" data-summary-body>
              <p style="margin: 0; color: var(--color-body); font-size: var(--text-body-sm);">
                As you fill out the form, your brief will appear here so you can
                see exactly what students will see.
              </p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  {/* ── Success state (hidden until publish) ─────────────── */}
  <div
    class="post-success"
    data-success-state
    hidden
    role="status"
    aria-live="polite"
  >
    <div class="ds-container post-success__inner">
      <div class="post-success__card">
        <span class="auth-success__icon" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none">
            <path d="M6 14.5l5 5L22 8.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <h2 class="auth-success__title">Your brief is live</h2>
        <p class="auth-success__body">
          Brief <code class="post-success__id" data-success-id>—</code> has been
          published. Students can apply right away and you'll see ranked
          applicants in your dashboard.
        </p>
        <p class="post-success__redirect" data-success-redirect>
          Taking you to your dashboard in a moment…
        </p>
        <div class="post-success__actions">
          <Button variant="primary" size="md" href="/company/dashboard">Go to dashboard now</Button>
          <Button variant="secondary" size="md" href="/jobs/post">Post another</Button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { mountPostForm } from '../../scripts/post-form';
    mountPostForm();
  </script>
</Layout>

<style>
  .skip-link {
    position: absolute;
    top: -40px;
    left: 16px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    font-size: var(--text-body-sm);
    z-index: 100;
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 16px;
  }

  /* Top nav (re-uses the design-system nav brand) */
  .post-top {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--color-canvas) 86%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--color-hairline);
  }
  .post-top__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    height: 64px;
  }
  .post-top__nav {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .post-top__link {
    display: inline-flex;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    color: var(--color-body);
    font-size: var(--text-body-sm);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .post-top__link:hover {
    color: var(--color-ink);
    background: var(--color-canvas-soft);
  }
  .post-top__right {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  @media (max-width: 700px) {
    .post-top__nav {
      display: none;
    }
  }

  /* Page */
  .post-page {
    padding-block: var(--space-3xl) var(--space-5xl);
  }
  .post-page__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }
  .post-page__head {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .post-page__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-mute);
  }
  .post-page__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-ink);
    margin: 0;
  }
  .post-page__lead {
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
    color: var(--color-body);
    margin: 0;
  }
  .post-page__fields {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: var(--space-sm) 0 0;
    padding: 0;
  }
  .post-page__fields li {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-full);
    font-size: var(--text-caption);
    color: var(--color-ink);
    white-space: nowrap;
  }

  /* Two-column form + summary */
  .post-grid {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 1000px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  /* Per-field inline error appended by post-form.ts. Visible in
   * both light and dark mode because it consumes the token-driven
   * --color-error / --color-error-deep pair. */
  .post-form :global(.ds-field__error) {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    font-size: var(--text-caption);
    line-height: var(--text-body-sm-line);
    color: var(--color-error);
    animation: post-fade-in 0.18s ease;
  }
  .post-form :global(.ds-field__error)::before {
    content: "";
    display: inline-block;
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    background-color: var(--color-error);
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><path d='M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm0 3.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 8 5Zm0 7.5a.9.9 0 1 1 0-1.8.9.9 0 0 1 0 1.8Z' fill='black'/></svg>")
      center / contain no-repeat;
    mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><path d='M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm0 3.5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 8 5Zm0 7.5a.9.9 0 1 1 0-1.8.9.9 0 0 1 0 1.8Z' fill='black'/></svg>")
      center / contain no-repeat;
  }
  .post-form :global(.ds-field__hint) {
    font-size: var(--text-caption);
    line-height: var(--text-caption-line);
    color: var(--color-mute);
  }

  /* Inline form-level alert — compact, friendly, dismissible.
   * Sits at the top of the form but takes the minimum vertical
   * space so a validation pass never feels like a full-page
   * error takeover. The first invalid field below still gets
   * focus and its own per-field message. */
  .post-alert {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-error) 10%, var(--color-canvas));
    color: var(--color-error-deep);
    border: 1px solid color-mix(in srgb, var(--color-error) 25%, var(--color-hairline));
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm-line);
    animation: post-fade-in 0.18s ease;
  }
  .post-alert[hidden] {
    display: none;
  }
  .post-alert__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--color-error);
  }
  .post-alert__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .post-alert__title {
    margin: 0;
    font-weight: var(--text-body-sm-strong-weight);
    color: var(--color-ink);
  }
  .post-alert__msg {
    margin: 0;
    color: var(--color-error-deep);
  }
  .post-alert__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    border-radius: var(--radius-xs);
    background: transparent;
    border: 0;
    color: var(--color-error);
    cursor: pointer;
    transition: background-color 0.12s ease, color 0.12s ease;
  }
  .post-alert__close:hover {
    background: color-mix(in srgb, var(--color-error) 12%, transparent);
    color: var(--color-error-deep);
  }
