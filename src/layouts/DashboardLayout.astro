---
/**
 * DashboardLayout
 *
 * Shared shell for /student/dashboard and /company/dashboard.
 *   - Top nav: brand mark, role pill, search affordance (placeholder),
 *     theme toggle, avatar placeholder.
 *   - Side rail: primary nav for the role. Collapses to a horizontal
 *     scroll on narrow viewports.
 *   - Main: page body via <slot />.
 *
 * The "name" and "role" props are placeholder strings until the
 * authenticated session is wired up. They are displayed prominently
 * but never claim to be a real, verified account.
 */
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/dashboard.css';
import '../styles/toast.css';
import ThemeBoot from '../components/ui/ThemeBoot.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';
import StudentNav from '../components/StudentNav.astro';

export interface NavItem {
  href: string;
  label: string;
  /** Optional SVG path / icon key */
  icon?: 'home' | 'brief' | 'inbox' | 'wallet' | 'profile' | 'gigs' | 'reviews' | 'settings';
  /** Marks the current page */
  current?: boolean;
}

interface Props {
  title: string;
  description?: string;
  /** Display name in the top nav. Placeholder until auth is wired. */
  name: string;
  /** "Student" or "Company" */
  role: 'Student' | 'Company';
  /** Side-rail nav items for this role */
  nav: NavItem[];
}

const {
  title,
  description = 'StudentLancers dashboard',
  name,
  role,
  nav,
} = Astro.props as Props;

const initials = name
  .split(' ')
  .map((p) => p[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase();

const pageAuth = role.toLowerCase() === 'company' ? 'company' : 'student';


---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ThemeBoot />
    <script is:inline define:vars={{ pageAuth }}>
      (function () {
        try {
          var raw = localStorage.getItem('sl-session');
          var session = raw ? JSON.parse(raw) : null;
          var path = window.location.pathname || '/';
          var dash = function (role) {
            return role === 'company' ? '/company/dashboard' : '/student/dashboard';
          };
          if (!session) {
            window.location.replace('/login?next=' + encodeURIComponent(path));
            return;
          }
          if (session.role !== pageAuth) {
            window.location.replace(dash(session.role));
            return;
          }
        } catch (e) {
          // Storage unavailable — let the client-side guard handle it.
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
    />
  </head>
  <body class="dash-body" data-page-auth={pageAuth}>
    <a class="skip-link" href="#dash-main">Skip to content</a>

    <header class="dash-top" data-dash-top>
      <div class="ds-container dash-top__inner">
        <StudentNav nav={nav} />

        <nav class="dash-top__center" aria-label="Role">
          <span class="dash-role-pill" data-role={role.toLowerCase()}>
            {role} dashboard
          </span>
        </nav>

        <div class="dash-top__right">
          <ThemeToggle size="md" />
          <button class="dash-notif-btn" type="button" aria-label="Notifications" data-notif-bell>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M13.5 6.75a4.5 4.5 0 1 0-9 0c0 5.25-2.25 6.75-2.25 6.75h13.5s-2.25-1.5-2.25-6.75" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10.3 15.75a1.5 1.5 0 0 1-2.6 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="dash-notif-badge" data-notif-badge hidden>0</span>
          </button>
          <button class="dash-avatar" type="button" aria-label="Account menu" data-avatar>
            <span class="dash-avatar__initials" aria-hidden="true">{initials || '·'}</span>
          </button>
          <div class="dash-user-pill" data-user-pill>
            <span class="dash-user-pill__name">{name.split(' ')[0]}</span>
            <span class="dash-user-pill__role">{role}</span>
          </div>
        </div>
      </div>
    </header>

    <div class="dash-shell" id="dash-main">
      <aside class="dash-rail" aria-label="Primary">
        <nav class="dash-rail__nav" role="list">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={['dash-rail__item', item.current && 'is-current']}
              aria-current={item.current ? 'page' : undefined}
              role="listitem"
            >
              <span class="dash-rail__icon" aria-hidden="true">
                {item.icon === 'home' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M2 7l6-5 6 5v6.5a.5.5 0 0 1-.5.5h-3v-4h-5v4h-3a.5.5 0 0 1-.5-.5V7Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'brief' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="4.5" width="12" height="8.5" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M6 4.5V3.5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.4" />
                  </svg>
                )}
                {item.icon === 'inbox' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M2 9.5L3.5 4h9L14 9.5v3a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    <path d="M2 9.5h3.5l1 1.5h3l1-1.5H14" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'wallet' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="4" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M2 7h12" stroke="currentColor" stroke-width="1.4" />
                    <circle cx="11" cy="10" r="1" fill="currentColor" />
                  </svg>
                )}
                {item.icon === 'profile' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M3 13c.5-2.4 2.6-4 5-4s4.5 1.6 5 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                )}
                {item.icon === 'gigs' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 3h4l1 1.5h5v8a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'reviews' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 1.5l1.7 3.6 4 .5-2.9 2.7.7 3.9L8 10.4l-3.5 1.8.7-3.9L2.3 5.6l4-.5L8 1.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'settings' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4" />
                    <path d="M8 1.5v2M8 12.5v2M14.5 8h-2M3.5 8h-2M12.6 3.4l-1.4 1.4M4.8 11.2l-1.4 1.4M12.6 12.6l-1.4-1.4M4.8 4.8L3.4 3.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                )}
              </span>
              <span class="dash-rail__label">{item.label}</span>
            </a>
          ))}
        </nav>

        <div class="dash-rail__foot">
          <button type="button" class="dash-rail__signout" data-rail-logout>Log out</button>
        </div>
      </aside>

      <main class="dash-main">
        <div class="ds-container dash-main__inner">
          <slot />
        </div>
      </main>
    </div>

    <div class="sl-toast-root" data-toast-root role="region" aria-live="polite" aria-label="Notifications"></div>

    <script>
      import { mountThemeToggle } from '../scripts/theme-toggle';
      mountThemeToggle();
      import { mountSessionBar } from '../scripts/session-bar';
      mountSessionBar();
      import { mountAuthGuards } from '../scripts/auth-guards';
      mountAuthGuards();

      // Shadow the top nav once it scrolls past the initial offset so
      // long pages get a clear visual boundary.
      const top = document.querySelector<HTMLElement>('[data-dash-top]');
      if (top) {
        const onScroll = () => {
          if (window.scrollY > 4) top.setAttribute('data-scrolled', '');
          else top.removeAttribute('data-scrolled');
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // Rail logout button
      const railLogout = document.querySelector<HTMLButtonElement>('[data-rail-logout]');
      if (railLogout) {
        railLogout.addEventListener('click', async () => {
          const { signOut } = await import('../scripts/session-bar');
          void signOut();
        });
      }

      // Notification bell mock (shows badge demo)
      const notifBell = document.querySelector<HTMLButtonElement>('[data-notif-bell]');
      const notifBadge = document.querySelector<HTMLElement>('[data-notif-badge]');
      if (notifBell && notifBadge) {
        notifBell.addEventListener('click', () => {
          notifBadge.hidden = !notifBadge.hidden;
        });
      }
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
