---
/**
 * DashboardLayout
 *
 * Shared shell for /student/dashboard and /company/dashboard.
 *   - Top nav: brand mark, role pill, search affordance (placeholder),
 *     theme toggle, avatar placeholder.
 *   - Side rail: primary nav for the role. Collapses to a horizontal
 *     scroll on narrow viewports.
 *   - Main: page body via <slot />.
 *
 * The "name" and "role" props are placeholder strings until the
 * authenticated session is wired up. They are displayed prominently
 * but never claim to be a real, verified account.
 */
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/dashboard.css';
import ThemeBoot from '../components/ui/ThemeBoot.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';

export interface NavItem {
  href: string;
  label: string;
  /** Optional SVG path / icon key */
  icon?: 'home' | 'brief' | 'inbox' | 'wallet' | 'profile' | 'gigs' | 'reviews' | 'settings';
  /** Marks the current page */
  current?: boolean;
}

interface Props {
  title: string;
  description?: string;
  /** Display name in the top nav. Placeholder until auth is wired. */
  name: string;
  /** "Student" or "Company" */
  role: 'Student' | 'Company';
  /** Side-rail nav items for this role */
  nav: NavItem[];
}

const {
  title,
  description = 'StudentLancers dashboard',
  name,
  role,
  nav,
} = Astro.props as Props;

const initials = name
  .split(' ')
  .map((p) => p[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ThemeBoot />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
    />
  </head>
  <body class="dash-body">
    <a class="skip-link" href="#dash-main">Skip to content</a>

    <header class="dash-top" data-dash-top>
      <div class="ds-container dash-top__inner">
        <a href="/" class="nav__brand" aria-label="StudentLancers home">
          <span class="nav__logo" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <rect x="0.5" y="0.5" width="21" height="21" rx="5.5" fill="var(--color-primary)" />
              <path
                d="M6 7.5L11 4.5L16 7.5V14.5L11 17.5L6 14.5V7.5Z"
                stroke="white"
                stroke-width="1.4"
                stroke-linejoin="round"
              />
              <path
                d="M11 4.5V11M11 11L16 7.5M11 11L6 7.5M11 11V17.5"
                stroke="white"
                stroke-width="1.4"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span class="nav__brand-text">StudentLancers</span>
        </a>

        <nav class="dash-top__center" aria-label="Role">
          <span class="dash-role-pill" data-role={role.toLowerCase()}>
            {role} dashboard
          </span>
        </nav>

        <div class="dash-top__right">
          <ThemeToggle size="md" />
          <button class="dash-avatar" type="button" aria-label="Account menu" data-avatar>
            <span class="dash-avatar__initials" aria-hidden="true">{initials || '·'}</span>
          </button>
        </div>
      </div>
    </header>

    <div class="dash-shell" id="dash-main">
      <aside class="dash-rail" aria-label="Primary">
        <nav class="dash-rail__nav" role="list">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={['dash-rail__item', item.current && 'is-current']}
              aria-current={item.current ? 'page' : undefined}
              role="listitem"
            >
              <span class="dash-rail__icon" aria-hidden="true">
                {item.icon === 'home' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M2 7l6-5 6 5v6.5a.5.5 0 0 1-.5.5h-3v-4h-5v4h-3a.5.5 0 0 1-.5-.5V7Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'brief' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="4.5" width="12" height="8.5" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M6 4.5V3.5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.4" />
                  </svg>
                )}
                {item.icon === 'inbox' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M2 9.5L3.5 4h9L14 9.5v3a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    <path d="M2 9.5h3.5l1 1.5h3l1-1.5H14" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'wallet' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="4" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M2 7h12" stroke="currentColor" stroke-width="1.4" />
                    <circle cx="11" cy="10" r="1" fill="currentColor" />
                  </svg>
                )}
                {item.icon === 'profile' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.4" />
                    <path d="M3 13c.5-2.4 2.6-4 5-4s4.5 1.6 5 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                )}
                {item.icon === 'gigs' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 3h4l1 1.5h5v8a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'reviews' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 1.5l1.7 3.6 4 .5-2.9 2.7.7 3.9L8 10.4l-3.5 1.8.7-3.9L2.3 5.6l4-.5L8 1.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  </svg>
                )}
                {item.icon === 'settings' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4" />
                    <path d="M8 1.5v2M8 12.5v2M14.5 8h-2M3.5 8h-2M12.6 3.4l-1.4 1.4M4.8 11.2l-1.4 1.4M12.6 12.6l-1.4-1.4M4.8 4.8L3.4 3.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                )}
              </span>
              <span class="dash-rail__label">{item.label}</span>
            </a>
          ))}
        </nav>

        <div class="dash-rail__foot">
          <a href="/login" class="dash-rail__signout">Switch account</a>
        </div>
      </aside>

      <main class="dash-main">
        <div class="ds-container dash-main__inner">
          <slot />
        </div>
      </main>
    </div>

    <script>
      import { mountThemeToggle } from '../scripts/theme-toggle';
      mountThemeToggle();
      import { mountSessionBar } from '../scripts/session-bar';
      mountSessionBar();

      // Shadow the top nav once it scrolls past the initial offset so
      // long pages get a clear visual boundary.
      const top = document.querySelector<HTMLElement>('[data-dash-top]');
      if (top) {
        const onScroll = () => {
          if (window.scrollY > 4) top.setAttribute('data-scrolled', '');
          else top.removeAttribute('data-scrolled');
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }

      // "Switch account" is shorthand for sign out + go to the login page.
      const signoutLinks = document.querySelectorAll<HTMLAnchorElement>('.dash-rail__signout');
      signoutLinks.forEach((a) => {
        a.addEventListener('click', async (event) => {
          event.preventDefault();
          const { store } = await import('../scripts/store');
          store.auth.signOut();
          window.location.href = '/login';
        });
      });
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
