---
import '../styles/tokens.css';
import '../styles/global.css';
import ThemeBoot from '../components/ui/ThemeBoot.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'StudentLancers — Hire college talent. Earn while you learn.',
  description = 'The freelance marketplace built for college students and the companies that hire them. Find affordable student talent or land gigs that fit your schedule.',
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<ThemeBoot />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
		/>
	</head>
	<body>
		<slot />
		<script>
			import { mountThemeToggle } from '../scripts/theme-toggle';
			mountThemeToggle();
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
