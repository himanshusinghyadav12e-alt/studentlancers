---
/**
 * AuthLayout
 *
 * Shared shell for /login, /signup, and /forgot-password. Two-pane layout:
 *   - Left: dark brand panel with the same gradient mesh and bullets used
 *     on the homepage hero, kept deliberately compact.
 *   - Right: light form panel that hosts the page body.
 *
 * Token-driven only — every color, type, space, radius, and shadow comes
 * from tokens.css so the design system stays the single source of truth.
 */
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/auth.css';
import '../styles/toast.css';
import ThemeBoot from '../components/ui/ThemeBoot.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  /** Eyebrow chip rendered above the heading (e.g. "Welcome back") */
  eyebrow?: string;
  /** Headline rendered as <h1> */
  heading: string;
  /** Optional subheading copy under the headline */
  subheading?: string;
}

const {
  title,
  description = 'Sign in to your StudentLancers account.',
  eyebrow,
  heading,
  subheading,
} = Astro.props as Props;

// Auth pages are always guest-only — signed-in users should bounce to
// their dashboard before the form ever paints.
const pageAuth = 'guest-only';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ThemeBoot />
    <script is:inline define:vars={{ pageAuth }}>
      (function () {
        try {
          if (pageAuth === 'public') return;
          var raw = localStorage.getItem('sl-session');
          var session = raw ? JSON.parse(raw) : null;
          var path = window.location.pathname || '/';
          function safeNext(n) {
            if (!n || typeof n !== 'string') return null;
            if (!n.startsWith('/') || n.startsWith('//')) return null;
            return n;
          }
          var dash = function (role) {
            return role === 'company' ? '/company/dashboard' : '/student/dashboard';
          };
          if (pageAuth === 'guest-only' && session) {
            var params = new URLSearchParams(window.location.search);
            var next = safeNext(params.get('next')) || dash(session.role);
            window.location.replace(next);
            return;
          }
          if ((pageAuth === 'student' || pageAuth === 'company') && !session) {
            window.location.replace('/login?next=' + encodeURIComponent(path));
            return;
          }
          if ((pageAuth === 'student' || pageAuth === 'company') && session && session.role !== pageAuth) {
            window.location.replace(dash(session.role));
            return;
          }
        } catch (e) {
          // Fallback to client-side guard.
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
    />
  </head>
  <body class="auth-body" data-page-auth={pageAuth}>
    <a class="skip-link" href="#auth-main">Skip to content</a>

    <main id="auth-main" class="auth-shell">
      <section class="auth-pane auth-pane--brand" aria-hidden="false">
        <div class="auth-pane__mesh"></div>

        <div class="auth-pane__inner">
          <a href="/" class="auth-brand" aria-label="StudentLancers home">
            <span class="auth-brand__logo" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <rect x="0.5" y="0.5" width="21" height="21" rx="5.5" fill="var(--inverted-fg)" />
                <path
                  d="M6 7.5L11 4.5L16 7.5V14.5L11 17.5L6 14.5V7.5Z"
                  stroke="var(--inverted-bg)"
                  stroke-width="1.4"
                  stroke-linejoin="round"
                />
                <path
                  d="M11 4.5V11M11 11L16 7.5M11 11L6 7.5M11 11V17.5"
                  stroke="var(--inverted-bg)"
                  stroke-width="1.4"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
            <span class="auth-brand__text">StudentLancers</span>
          </a>

          <div class="auth-pane__toggle">
            <ThemeToggle size="sm" />
          </div>

          <div class="auth-pane__copy">
            <p class="auth-pane__eyebrow">Built for students &amp; the companies that hire them</p>
            <h2 class="auth-pane__quote">
              "StudentLancers is the only place we hire for landing-page work. The talent is sharper than
              agencies we have used, and a fraction of the cost."
            </h2>
            <p class="auth-pane__attr">
              <strong>Daniel Park</strong> · Founder, Linear Labs
            </p>
          </div>

          <ul class="auth-pane__bullets" role="list">
            <li>
              <span class="auth-pane__dot" aria-hidden="true"></span>
              Vetted college talent across 40+ majors
            </li>
            <li>
              <span class="auth-pane__dot" aria-hidden="true"></span>
              Escrow on every engagement
            </li>
            <li>
              <span class="auth-pane__dot" aria-hidden="true"></span>
              Free to join — no card required
            </li>
          </ul>
        </div>

        <div class="auth-pane__foot" aria-hidden="true">
          <span>© {new Date().getFullYear()} StudentLancers, Inc.</span>
        </div>
      </section>

      <section class="auth-pane auth-pane--form">
        <div class="auth-pane__form-inner">
          <header class="auth-header">
            {eyebrow && <span class="auth-header__eyebrow">{eyebrow}</span>}
            <h1 class="auth-header__title">{heading}</h1>
            {subheading && <p class="auth-header__lead">{subheading}</p>}
          </header>

          <slot />

          <footer class="auth-foot">
            <ul class="auth-foot__links" role="list">
              <li><a href="/privacy">Privacy</a></li>
              <li><a href="/terms">Terms</a></li>
              <li><a href="/contact">Support</a></li>
            </ul>
            <p class="auth-foot__copy">
              © {new Date().getFullYear()} StudentLancers, Inc.
            </p>
          </footer>
        </div>
      </section>
    </main>

    <div class="sl-toast-root" data-toast-root role="region" aria-live="polite" aria-label="Notifications"></div>

    <script>
      import { mountThemeToggle } from '../scripts/theme-toggle';
      mountThemeToggle();
      import { mountSessionBar } from '../scripts/session-bar';
      mountSessionBar();
      import { mountAuthGuards } from '../scripts/auth-guards';
      mountAuthGuards();
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
