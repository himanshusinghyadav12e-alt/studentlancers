---
import Layout from './Layout.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heading: string;
  lead?: string;
}

const { title, description, eyebrow, heading, lead } = Astro.props as Props;
---

<Layout title={title} description={description}>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="info-top">
    <div class="ds-container info-top__inner">
      <a href="/" class="nav__brand" aria-label="StudentLancers home">
        <span class="nav__logo" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <rect x="0.5" y="0.5" width="21" height="21" rx="5.5" fill="var(--color-primary)" />
            <path d="M6 7.5L11 4.5L16 7.5V14.5L11 17.5L6 14.5V7.5Z" stroke="white" stroke-width="1.4" stroke-linejoin="round" />
            <path d="M11 4.5V11M11 11L16 7.5M11 11L6 7.5M11 11V17.5" stroke="white" stroke-width="1.4" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="nav__brand-text">StudentLancers</span>
      </a>
      <div class="info-top__right">
        <ThemeToggle size="md" />
        <Button variant="secondary-sm" size="md" href="/">Back to home</Button>
      </div>
    </div>
  </header>

  <main id="main" class="info-page">
    <div class="ds-container info-page__inner">
      <header class="info-page__head">
        {eyebrow && <span class="info-page__eyebrow">{eyebrow}</span>}
        <h1 class="info-page__title">{heading}</h1>
        {lead && <p class="info-page__lead">{lead}</p>}
      </header>
      <article class="info-page__body">
        <slot />
      </article>
    </div>
  </main>
</Layout>

<style>
  .skip-link {
    position: absolute;
    top: -40px;
    left: 16px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    font-size: var(--text-body-sm);
    z-index: 100;
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 16px;
  }
  .info-top {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--color-canvas) 86%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--color-hairline);
  }
  .info-top__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    height: 64px;
  }
  .info-top__right {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .info-page {
    padding-block: var(--space-3xl) var(--space-5xl);
  }
  .info-page__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }
  .info-page__head {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .info-page__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-mute);
  }
  .info-page__title {
    font-size: clamp(28px, 4vw, var(--text-display-lg));
    line-height: var(--text-display-lg-line);
    font-weight: var(--text-display-lg-weight);
    letter-spacing: var(--text-display-lg-tracking);
    color: var(--color-ink);
    margin: 0;
  }
  .info-page__lead {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg-line);
    color: var(--color-body);
    margin: 0;
  }
  .info-page__body {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    color: var(--color-body);
  }
  .info-page__body h2 {
    font-size: var(--text-display-sm);
    line-height: var(--text-display-sm-line);
    font-weight: var(--text-display-sm-weight);
    color: var(--color-ink);
    margin: var(--space-md) 0 0;
  }
  .info-page__body p {
    margin: 0;
    font-size: var(--text-body-md);
    line-height: var(--text-body-md-line);
  }
  .info-page__body ul {
    margin: 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .info-page__body a {
    color: var(--color-link);
  }
</style>
