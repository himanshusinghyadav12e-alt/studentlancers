---
/**
 * ThemeBoot
 *
 * Renders the inline head script that sets data-theme on <html> BEFORE
 * any paint, preventing the flash of incorrect theme. Reads the saved
 * theme from localStorage and falls back to prefers-color-scheme.
 *
 * Also wires the [data-theme-toggle] buttons anywhere in the document.
 */
---

<script is:inline>
  // No-flash theme bootstrap. Must be inline + synchronous.
  (function () {
    try {
      var saved = localStorage.getItem('sl-theme');
      if (saved === 'dark' || saved === 'light') {
        document.documentElement.setAttribute('data-theme', saved);
      } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    } catch (_) {
      // localStorage unavailable (private mode, etc.) — fall through to OS preference
    }
  })();
</script>
