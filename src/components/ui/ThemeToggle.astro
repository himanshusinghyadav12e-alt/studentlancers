---
/**
 * ThemeToggle
 *
 * Sun/moon button that flips the document's data-theme between "light"
 * and "dark". Persists the choice in localStorage. The no-flash theme
 * attribute is set in global.css (a synchronous head script) before any
 * paint, so this component is purely an interactive control.
 */
export interface Props {
  /** Visual scale — `md` matches the homepage nav, `sm` matches the auth shell */
  size?: 'sm' | 'md';
  class?: string;
}

const { size = 'md', class: className } = Astro.props as Props;

const classes = ['theme-toggle', `theme-toggle--${size}`, className].filter(Boolean).join(' ');
---

<button
  type="button"
  class={classes}
  data-theme-toggle
  aria-label="Toggle dark mode"
  aria-pressed="false"
  title="Toggle theme"
>
  <svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 16 16" fill="none" aria-hidden="true">
    <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.4" />
    <path
      d="M8 1.5v1.8M8 12.7v1.8M14.5 8h-1.8M3.3 8H1.5M12.6 3.4l-1.3 1.3M4.7 11.3l-1.3 1.3M12.6 12.6l-1.3-1.3M4.7 4.7L3.4 3.4"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
    />
  </svg>
  <svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
    <path
      d="M13.5 9.5A5.5 5.5 0 1 1 6.5 2.5a4.5 4.5 0 0 0 7 7Z"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linejoin="round"
    />
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    color: var(--color-body);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .theme-toggle--sm {
    width: 32px;
    height: 32px;
  }
  .theme-toggle:hover {
    color: var(--color-ink);
    background: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }
  .theme-toggle:active {
    transform: scale(0.95);
  }
  .theme-toggle__icon {
    width: 16px;
    height: 16px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  /* Light mode → show moon (click to go dark) */
  :root:not([data-theme="dark"]) .theme-toggle__icon--sun {
    display: none;
  }
  [data-theme="dark"] .theme-toggle__icon--moon {
    display: none;
  }
</style>
