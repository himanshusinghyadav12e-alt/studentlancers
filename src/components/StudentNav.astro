---
/**
 * StudentNav
 *
 * Chrome-style navigation bar for all student/company pages.
 * Renders:
 *   - Hamburger menu (mobile only) → slide-out drawer with nav items
 *   - Back/forward chevron buttons (desktop only)
 *   - StudentLancers brand logo
 *
 * The drawer receives its items from the parent layout via the
 * `nav` prop. On desktop the side rail serves the same purpose.
 */
export interface NavItem {
  href: string;
  label: string;
  icon?: 'home' | 'brief' | 'inbox' | 'wallet' | 'profile' | 'gigs' | 'reviews' | 'settings';
  current?: boolean;
}

interface Props {
  prevHref?: string;
  nextHref?: string;
  /** Nav items for the mobile drawer (pass from DashboardLayout) */
  nav?: NavItem[];
}

const { prevHref, nextHref, nav = [] } = Astro.props as Props;
---

<div class="student-nav">
  {/* Hamburger — mobile only */}
  <button
    class="mn-hamburger"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mn-drawer"
    data-mn-toggle
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  </button>

  {/* Prev / Next — desktop only */}
  <nav class="student-nav__arrows" aria-label="Page navigation">
    <a
      href={prevHref}
      class:list={['student-nav__btn', !prevHref && 'is-disabled']}
      aria-disabled={!prevHref || undefined}
      aria-label="Previous page"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
    <a
      href={nextHref}
      class:list={['student-nav__btn', !nextHref && 'is-disabled']}
      aria-disabled={!nextHref || undefined}
      aria-label="Next page"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </nav>

  <a href="/" class="nav__brand" aria-label="StudentLancers home">
    <span class="nav__logo" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
        <rect x="0.5" y="0.5" width="21" height="21" rx="5.5" fill="var(--color-primary)" />
        <path
          d="M6 7.5L11 4.5L16 7.5V14.5L11 17.5L6 14.5V7.5Z"
          stroke="var(--color-on-primary)"
          stroke-width="1.4"
          stroke-linejoin="round"
        />
        <path
          d="M11 4.5V11M11 11L16 7.5M11 11L6 7.5M11 11V17.5"
          stroke="var(--color-on-primary)"
          stroke-width="1.4"
          stroke-linejoin="round"
        />
      </svg>
    </span>
    <span class="nav__brand-text">StudentLancers</span>
  </a>
</div>

{/* ─── Mobile drawer ────────────────────────────────────────── */}
<div class="mn-backdrop" data-mn-backdrop hidden />
<aside
  class="mn-drawer"
  id="mn-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
  data-mn-drawer
  hidden
>
  <div class="mn-drawer__head">
    <a href="/" class="nav__brand" aria-label="StudentLancers home">
      <span class="nav__logo" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <rect x="0.5" y="0.5" width="21" height="21" rx="5.5" fill="var(--color-primary)" />
          <path
            d="M6 7.5L11 4.5L16 7.5V14.5L11 17.5L6 14.5V7.5Z"
            stroke="var(--color-on-primary)"
            stroke-width="1.4"
            stroke-linejoin="round"
          />
          <path
            d="M11 4.5V11M11 11L16 7.5M11 11L6 7.5M11 11V17.5"
            stroke="var(--color-on-primary)"
            stroke-width="1.4"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="nav__brand-text">StudentLancers</span>
    </a>
    <button
      class="mn-drawer__close"
      type="button"
      aria-label="Close navigation menu"
      data-mn-close
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M4.5 4.5l9 9M13.5 4.5l-9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <nav class="mn-drawer__nav" aria-label="Primary">
    {nav.map((item) => (
      <a
        href={item.href}
        class:list={['mn-drawer__item', item.current && 'is-current']}
        aria-current={item.current ? 'page' : undefined}
        data-mn-item
      >
        <span class="mn-drawer__icon" aria-hidden="true">
          {item.icon === 'home' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <path d="M2 7l6-5 6 5v6.5a.5.5 0 0 1-.5.5h-3v-4h-5v4h-3a.5.5 0 0 1-.5-.5V7Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            </svg>
          )}
          {item.icon === 'brief' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="4.5" width="12" height="8.5" rx="1.5" stroke="currentColor" stroke-width="1.4" />
              <path d="M6 4.5V3.5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.4" />
            </svg>
          )}
          {item.icon === 'inbox' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <path d="M2 9.5L3.5 4h9L14 9.5v3a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
              <path d="M2 9.5h3.5l1 1.5h3l1-1.5H14" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            </svg>
          )}
          {item.icon === 'wallet' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="4" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" />
              <path d="M2 7h12" stroke="currentColor" stroke-width="1.4" />
              <circle cx="11" cy="10" r="1" fill="currentColor" />
            </svg>
          )}
          {item.icon === 'profile' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.4" />
              <path d="M3 13c.5-2.4 2.6-4 5-4s4.5 1.6 5 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg>
          )}
          {item.icon === 'gigs' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <path d="M3 3h4l1 1.5h5v8a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            </svg>
          )}
          {item.icon === 'reviews' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <path d="M8 1.5l1.7 3.6 4 .5-2.9 2.7.7 3.9L8 10.4l-3.5 1.8.7-3.9L2.3 5.6l4-.5L8 1.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            </svg>
          )}
          {item.icon === 'settings' && (
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4" />
              <path d="M8 1.5v2M8 12.5v2M14.5 8h-2M3.5 8h-2M12.6 3.4l-1.4 1.4M4.8 11.2l-1.4 1.4M12.6 12.6l-1.4-1.4M4.8 4.8L3.4 3.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg>
          )}
        </span>
        <span class="mn-drawer__label">{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="mn-drawer__foot">
    <a href="/login" class="mn-drawer__signout" data-mn-item>Switch account</a>
  </div>
</aside>

<script>
  /**
   * Mobile navigation drawer.
   *   - Toggle on hamburger click
   *   - Close on backdrop click, item click, or Escape
   *   - Trap focus inside drawer when open
   *   - Return focus to hamburger on close
   */
  function mount() {
    const toggle = document.querySelector<HTMLButtonElement>('[data-mn-toggle]');
    const drawer = document.querySelector<HTMLElement>('[data-mn-drawer]');
    const backdrop = document.querySelector<HTMLElement>('[data-mn-backdrop]');
    const closeBtn = document.querySelector<HTMLButtonElement>('[data-mn-close]');
    const items = document.querySelectorAll<HTMLElement>('[data-mn-item]');
    if (!toggle || !drawer || !backdrop) return;

    let lastFocused: HTMLElement | null = null;

    function open() {
      lastFocused = toggle;
      drawer.hidden = false;
      backdrop.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      // Focus first item or close button
      const first = drawer.querySelector<HTMLElement>('[data-mn-close]');
      first?.focus();
    }

    function close() {
      drawer.hidden = true;
      backdrop.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      lastFocused?.focus();
    }

    function isOpen() {
      return toggle.getAttribute('aria-expanded') === 'true';
    }

    toggle.addEventListener('click', () => {
      isOpen() ? close() : open();
    });

    backdrop.addEventListener('click', close);
    closeBtn?.addEventListener('click', close);

    items.forEach((item) => {
      item.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) {
        close();
        return;
      }
      // Focus trap
      if (e.key === 'Tab' && isOpen()) {
        const focusable = drawer.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        );
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });
  }

  mount();
</script>

<style>
  .student-nav {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .student-nav__arrows {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .student-nav__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    color: var(--color-ink);
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .student-nav__btn:hover:not(.is-disabled) {
    background: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }
  .student-nav__btn:active:not(.is-disabled) {
    background: var(--color-canvas-soft-2);
  }
  .student-nav__btn:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }
  .student-nav__btn.is-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ─── Hamburger — mobile only ──────────────────────────────── */
  .mn-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    color: var(--color-ink);
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .mn-hamburger:hover {
    background: var(--color-canvas-soft);
    border-color: var(--color-hairline-strong);
  }
  .mn-hamburger:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .student-nav__arrows {
      display: none;
    }
    .mn-hamburger {
      display: inline-flex;
    }
  }
</style>
